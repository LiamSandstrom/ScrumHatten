@using Models
@model List<Message>
@using System.Security.Claims

@{
    ViewData["Title"] = "Meddelanden";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

@section Styles {
    <link rel="stylesheet" href="~/css/message.css" />
}

<div class="container-fluid p-0"> 
    <div class="row g-0 bg-white shadow-sm chat-main-container">
        
        <div class="col-md-3 border-end p-0 bg-light contact-list-column">
            <div class="p-3 border-bottom bg-white flex-shrink-0">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Kollegor</h5>
                    <input type="text" id="userSearch" class="form-control form-control-sm rounded-pill w-50" placeholder="Sök...">
                </div>
            </div>

            <div class="p-3 border-bottom bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Grupper</h5>
                <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#createGroupModal">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>

            <div class="list-group list-group-flush border-bottom">
                @foreach (var group in (IEnumerable<GroupChat>)ViewBag.Groups)
                {
                    <a asp-action="Index" asp-route-groupId="@group.Id" class="list-group-item list-group-item-action py-3">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">G</div>
                            <h6 class="mb-0">@group.Name</h6>
                        </div>
                    </a>
                }
            </div>

            <div class="list-group list-group-flush scrollable-content">
                @foreach (var user in (IEnumerable<User>)ViewBag.Users)
                {
                    bool isSelected = ViewBag.SelectedUserId?.ToString() == user.Id.ToString();
                    <a asp-action="Index" asp-route-id="@user.Id" class="list-group-item list-group-item-action py-3 @(isSelected ? "active border-success" : "")">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; flex-shrink: 0;">
                                @(user.Name?[0].ToString().ToUpper() ?? "?")
                            </div>
                            <div class="text-truncate">
                                <h6 class="mb-0 text-truncate">@user.Name</h6>
                                <small class="text-secondary">Anställd</small>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div> <div class="col-md-9 p-0 chat-window-column bg-white">
            @if (ViewBag.SelectedUserId != null)
            {
                <div class="p-3 border-bottom bg-white d-flex justify-content-between align-items-center flex-shrink-0">
    <h5 class="mb-0">
        @if (ViewBag.IsGroupChat == true)
        {
            <span class="text-success">Gruppchatt:</span>
            @ViewBag.SelectedUserName
            <button class="btn btn-sm btn-outline-success ms-2" data-bs-toggle="modal" data-bs-target="#groupSettingsModal">
    <i class="bi bi-gear-fill me-1"></i> Hantera grupp
</button>
        }
        else
        {
            <span>Chatt med:</span> @ViewBag.SelectedUserName
        }
    </h5>
    
    @if (ViewBag.IsGroupChat == true)
    {
        <form asp-action="LeaveGroup" method="post" onsubmit="return confirm('Vill du verkligen lämna gruppen?')">
            <input type="hidden" name="groupId" value="@ViewBag.SelectedUserId" />
            <button type="submit" class="btn btn-sm btn-outline-danger">Lämna grupp</button>
        </form>
    }
</div>

                <div class="scrollable-content p-4" id="chatContainer">
                    @foreach (var msg in Model.OrderBy(m => m.Timestamp))
                    {
                        bool isSentByMe = msg.SenderId?.ToString() == currentUserId;
                        <div class="w-100 d-flex mb-3 @(isSentByMe ? "justify-content-end" : "justify-content-start")">
                            <div class="msg-bubble @(isSentByMe ? "sent" : "received")">
                                <p class="mb-1">@msg.Content</p>
                                <div class="text-end" style="font-size: 0.65rem; opacity: 0.8;">
                                    @msg.Timestamp.ToLocalTime().ToString("HH:mm")
                                    @if (ViewBag.IsGroupChat == true && !isSentByMe)
                                    {
                                        <small class="text-muted d-block mb-1">@msg.SenderName</small>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="chat-input-area">
                    <form asp-action="@(ViewBag.IsGroupChat == true ? "SendGroupMessage" : "SendMessage")" method="post" class="d-flex gap-2">
                        <input type="hidden" name="receiverId" value="@ViewBag.SelectedUserId" />
                        <input type="text" name="content" class="form-control rounded-pill" placeholder="Skriv ett meddelande..." required autocomplete="off" />
                        <button type="submit" class="btn btn-success rounded-circle px-3">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted bg-light">
                    <i class="bi bi-chat-dots" style="font-size: 4rem; opacity: 0.2;"></i>
                    <p>Välj en kollega för att börja chatta.</p>
                </div>
            }
        </div>
    </div>
</div>
<div class="modal fade" id="createGroupModal" tabindex="-1" aria-labelledby="createGroupModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateGroup" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="createGroupModalLabel">Skapa ny gruppchatt</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Gruppnamn</label>
                        <input type="text" name="groupName" class="form-control" placeholder="T.ex. Grupp 1" required />
                    </div>
                    
                    <h6>Välj kollegor som ska ingå:</h6>
                    <div style="max-height: 200px; overflow-y: auto;">
                        @foreach (var user in (IEnumerable<User>)ViewBag.Users)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="selectedUsers" value="@user.Id" id="user_@user.Id">
                                <label class="form-check-label" for="user_@user.Id">
                                    @user.Name
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Avbryt</button>
                    <button type="submit" class="btn btn-success">Skapa grupp</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="groupSettingsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Hantera @ViewBag.SelectedUserName</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                
                <h6>Nuvarande medlemmar</h6>
                <div class="list-group mb-4">
                @if (ViewBag.GroupMembers != null)
                {
                    @foreach (var member in (IEnumerable<User>)ViewBag.GroupMembers)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@member.Name</span>
                            <form asp-action="RemoveMember" method="post" class="m-0">
                                <input type="hidden" name="groupId" value="@ViewBag.SelectedUserId" />
                                <input type="hidden" name="userId" value="@member.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-person-dash"></i> Ta bort
                                </button>
                            </form>
                        </div>
                    }
                    }
                    else 
                    {
                        <p class="text-muted small">Inga medlemmar att visa.</p>
                    }
                </div>

                <hr />

                <h6>Lägg till kollegor</h6>
                <form asp-action="AddMembers" method="post">
                    <input type="hidden" name="groupId" value="@ViewBag.SelectedUserId" />
                    <div class="mb-3" style="max-height: 150px; overflow-y: auto;">
                    @if (ViewBag.NonMembers != null)
                    {
                        @foreach (var user in (IEnumerable<User>)ViewBag.NonMembers)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="newUserIds" value="@user.Id" id="add_@user.Id">
                                <label class="form-check-label" for="add_@user.Id">@user.Name</label>
                            </div>
                        }
                    }
                    </div>
                    <button type="submit" class="btn btn-sm btn-success w-100">
                        <i class="bi bi-person-plus"></i> Lägg till markerade
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/message.js"></script>
    <script>
        initMessaging("@ViewBag.SelectedUserId");
    </script>
}