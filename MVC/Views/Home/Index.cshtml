<script src="~/js/statistics.js"></script>
<script src="~/js/home.js"></script>
<link rel="stylesheet" href="~/css/statistics.css" />
<link rel="stylesheet" href="~/css/home.css" />

<div class="container mt-4">
    <div class="row">
        @if (User.Identity!.IsAuthenticated)
        {
            <div class="col-md-9">
                <h1>Välkommen @User.Identity.Name!</h1>
            </div>  }
        </div> 
    </div>

    <!--Widget container-->
    <div class="widgetFlexBox">

    <div class="statisticsContainer card"> 
        <div class="card-header" style="background-color: #006039; color : #ffffff ">
            <div class="cardHeaderContainer">
                <h5 class="mb-0">Försäljningsinsikter</h5>
                <a asp-controller="Statistics" asp-action="Overview">
                    <div>
                        <h5 class="mb-0">Se mer</h5> 
                    </div>
                </a>
            </div>

        </div>
        <div class="card-body">

        <!--Sum Sales card-->
        <div class="card m-3 salesSumCard" style="width: 25rem;">
            <div class="card-body">
                <h5 class="card-title">Summa omsättning <i class="bi bi-cash-coin"></i></h5>

                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderSum" id="pastYearSum">@pastYearsOrders kr</p>
                    <p class="card-text noDisplay hatSum" id="pastYearHatSum">@pastYearHatAmount hattar sålda senaste året</p>
                </div>
                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderSum" id="thisYearSum">@thisYearsOrders kr</p>
                    <p class="card-text noDisplay hatSum" id="thisYearHatSum">@thisYearHatAmount hattar sålda detta år</p>
                </div>

                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderSum" id="pastWeekSum">@pastWeeksOrders kr</p>
                    <p class="card-text noDisplay hatSum" id="pastWeekHatSum">@pastWeekHatAmount hattar sålda senaste veckan</p>
                </div>


                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderSum" id="pastMonthSum">@pastMonthsOrders kr</p>
                    <p class="card-text noDisplay hatSum" id="pastMonthHatSum">@pastMonthHatAmount hattar sålda senaste månaden</p>
                </div>


                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderSum" id="pastDaySum">@pastDaysOrders kr</p>
                    <p class="card-text noDisplay hatSum" id="pastDayHatSum">@pastDayHatAmount hattar sålda senaste 24 timmarna</p>
                </div>


                <div class="SalesSumContainer">
                    <p class="card-text  orderSum" id="thisDaySum">@thisDaysOrders kr</p>
                    <p class="card-text hatSum" id="thisDayHatSum">@thisDayHatAmount hattar sålda idag</p>
                </div>



                <div class="btn-group" role="group">
                    <button type="button" onclick="showSalesToday()" class="btn btn-outline-primary" id="thisDaySumBtn">TDY</button>
                    <button type="button" onclick="showSalesPastDay()" class="btn btn-outline-primary" id="pastDaySumBtn">1D</button>
                    <button type="button" onclick="showSalesPastWeek()" class="btn btn-outline-primary" id="pastWeekSUmBtn">1W</button>
                    <button type="button" onclick="showSalesPastMonth()" class="btn btn-outline-primary" id="pastMonthSumBtn">1M</button>
                    <button type="button" onclick="showSalesPastYear()" class="btn btn-outline-primary" id="pastYearSumBtn">1Y</button>
                    <button type="button" onclick="showSalesThisYear()" class="btn btn-outline-primary" id="thisYearSumBtn">YTD</button>
                </div>

            </div>

        </div>

        <!--Avg order worth-->
        <div class="card m-3 salesAvgCard" style="width: 25rem;">
            <div class="card-body">
                <h5 class="card-title">Medelsumma av order <i class="bi bi-plus-slash-minus"></i></h5>

                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderAvg" id="pastYearAvg">@pastYearsAvgOrder kr</p>
                </div>
                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderAvg" id="thisYearAvg">@thisYearsAvgOrder kr</p>
                </div>

                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderAvg" id="pastWeekAvg">@pastWeeksAvgOrder kr</p>
                </div>


                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderAvg" id="pastMonthAvg">@pastMonthAvgOrder kr</p>
                </div>


                <div class="SalesSumContainer">
                    <p class="card-text noDisplay orderAvg" id="pastDayAvg">@pastDaysAvgOrder kr</p>
                </div>

                <div class="SalesSumContainer">
                    <p class="card-text  orderAvg" id="thisDayAvg">@thisDaysAvgOrder kr</p>
                </div>



                <div class="btn-group" role="group">
                    <button type="button" onclick="showAvgSalesToday()" class="btn btn-outline-primary" id="thisDayAvgBtn">TDY</button>
                    <button type="button" onclick="showAvgSalesPastDay()" class="btn btn-outline-primary" id="pastDayAvgBtn">1D</button>
                    <button type="button" onclick="showAvgSalesPastWeek()" class="btn btn-outline-primary" id="pastWeekAvgBtn">1W</button>
                    <button type="button" onclick="showAvgSalesPastMonth()" class="btn btn-outline-primary" id="pastMonthAvgBtn">1M</button>
                    <button type="button" onclick="showAvgSalesPastYear()" class="btn btn-outline-primary" id="pastYearAvgBtn">1Y</button>
                    <button type="button" onclick="showAvgSalesThisYear()" class="btn btn-outline-primary" id="thisYearAvgBtn">YTD</button>
                </div>

            </div>

        </div>
        </div>
    </div>

<div class="container">
    <div class="row">
         <div class="col-md-3">
                <div class="card calenderWidget shadow-sm border-0">
                <div class="card-header" style="background-color: #006039; color : #ffffff ">
                    <h5 class="mb-0">Dagens aktiviteter</h5>
                </div>
                <div class="card-body p-0">
                    <ul id="today-events-list" class="list-group list-group-flush">
                        <li class="list-group-item text-muted">Laddar dagens schema...</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

    <div class="container">
        <div class="row">
            <div class="col-md-3">
                <div class="card inventoryWidget shadow-sm border-0">
                    <div class="card-header" style="background-color: #006039; color : #ffffff ">
                        <h5 class="mb-0">Lagerbevakning</h5>
                    </div>
                    <div class="card-body p-0">
                        <ul id="lowInventoryList" class="list-group list-group-flush">
                            <li class="list-group-item text-muted">Laddar dagens schema...</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="messageContainer card">
        <div class="card-header" style="background-color: #006039; color : #ffffff ">
            <div class="cardHeaderContainer">
                <h5 class="mb-0">Olästa meddelanden</h5>
                <a asp-controller="Message" asp-action="Index">
                    <div>
                        <h5 class="mb-0">Se mer</h5>
                    </div>
                </a>
            </div>

        </div>
        <div class="card-body">
            <ul id="messagesList" class="list-group list-group-flush">
                <li class="list-group-item text-muted">Inga olästa meddelanden</li>
            </ul>

        </div>
    </div>

</div>






@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            fetch('/Calendar/GetEvents')
                .then(res => res.json())
                .then(events => {
                    const list = document.getElementById('today-events-list');
                    const today = new Date().toLocaleDateString('sv-SE');

                    const todaysEvents = events.filter(e => 
                        new Date(e.start).toLocaleDateString('sv-SE') === today
                    );

                    if (todaysEvents.length === 0) {
                        list.innerHTML = '<li class="list-group-item">Inga händelser idag.</li>';
                        return;
                    }
                    list.innerHTML = todaysEvents.map(e => {
                     const time = new Date(e.start).toLocaleTimeString('sv-SE', {hour: '2-digit', minute:'2-digit'});
                         return `
                <li class="list-group-item d-flex align-items-center">
                 <span class="badge me-2" style="background-color: #D48B8B; color: white;">${time}</span>
                 <span class="text-dark">${e.title}</span>
                 </li>
    `
}).join('');
                });
        });
    </script>
}
