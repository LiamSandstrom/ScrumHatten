@model MVC.ViewModels.StatisticsViewModels.StatisticsOverviewViewModel

@{
    ViewData["Title"] = "Home Page";

    int thisYearsOrders = (int)Model.ThisYearsOrders.Sum(x => x.FinalPrice);
    int pastYearsOrders = (int)Model.PastYearsOrders.Sum(x => x.FinalPrice);
    int pastWeeksOrders = (int)Model.PastWeeksOrders.Sum(x => x.FinalPrice);
    int pastMonthsOrders = (int)Model.PastMonthsOrders.Sum(x => x.FinalPrice);
    int pastDaysOrders = (int)Model.PastDaysOrders.Sum(x => x.FinalPrice);
    int thisDaysOrders = (int)Model.ThisDaysOrders.Sum(x => x.FinalPrice);

    int thisYearHatAmount = Model.ThisYearsOrders.Sum(x => x.Hats.Count());
    int pastYearHatAmount = Model.PastYearsOrders.Sum(x => x.Hats.Count());
    int pastWeekHatAmount = Model.PastWeeksOrders.Sum(x => x.Hats.Count());
    int pastMonthHatAmount = Model.PastMonthsOrders.Sum(x => x.Hats.Count());
    int pastDayHatAmount = Model.PastDaysOrders.Sum(x => x.Hats.Count());
    int thisDayHatAmount = Model.ThisDaysOrders.Sum(x => x.Hats.Count());

    int thisYearsAvgOrder = (int)Model.ThisYearsOrders.Select(x => x.FinalPrice).DefaultIfEmpty(0).Average();
    int pastYearsAvgOrder = (int)Model.PastYearsOrders.Select(x => x.FinalPrice).DefaultIfEmpty(0).Average();
    int pastWeeksAvgOrder = (int)Model.PastWeeksOrders.Select(x => x.FinalPrice).DefaultIfEmpty(0).Average();
    int pastMonthAvgOrder = (int)Model.PastMonthsOrders.Select(x => x.FinalPrice).DefaultIfEmpty(0).Average();
    int pastDaysAvgOrder = (int)Model.PastDaysOrders.Select(x => x.FinalPrice).DefaultIfEmpty(0).Average();
    int thisDaysAvgOrder = (int)Model.ThisDaysOrders.Select(x => x.FinalPrice).DefaultIfEmpty(0).Average();

}


