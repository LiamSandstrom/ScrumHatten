
@model MVC.ViewModels.CustomerViewModels.HistoryCustomerViewModel
@{
}


<div class ="header-customer">

    <h2>@Model.Name</h2>

    <p>Kundhistorik</p>
</div>




<table class="table">
   
    <thead>
        <tr>
            <th scope="col">Ordernummer</th>
            <th scope="col">Orderdatum</th>
            <th scope="col">Totalpris</th>
            <th scope="col">Rabatt</th>
            <th scope="col">Status</th>
            
        </tr>
    </thead>
    <tbody>


        @foreach (var order in Model.allOrders)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.OrderDate</td>
                <td>@order.FinalPrice.ToString("C0", new System.Globalization.CultureInfo("sv-SE"))</td>
                <td>@order.Discount.ToString("P0")</td>
                <td>@order.Status</td>
              
            </tr>

          
        }

    </tbody>
</table>






















