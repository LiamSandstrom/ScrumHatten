@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>

    <div class="col-auto col-md-3 col-xl-2 px-sm-2 px-0 bg-dark" style="padding: 0;">
        <div class="d-flex flex-column align-items-center align-items-sm-start px-3 pt-2 text-white min-vh-100">

            <a asp-controller="Home" asp-action="Index"
                   class="d-flex align-items-center pb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                <span class="fs-5 d-none d-sm-inline">Menu</span>
            </a>

            <ul class="nav nav-pills flex-column mb-auto" id="menu">

                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link text-white">
                        Home
                    </a>
                </li>

                <li>
                    <a asp-controller="Home" asp-action="Privacy" class="nav-link text-white">
                        Privacy
                    </a>
                </li>

                <li>
                    <a asp-controller="Hat" asp-action="Index" class="nav-link text-white">
                        Alla hattar
                    </a>
                </li>
                <li>
                    <a asp-controller="Material" asp-action="Material" class="nav-link text-white">
                        Alla material
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <li>
                        <a asp-controller="Account" asp-action="Register" class="nav-link text-white">
                            + Lägg till användare
                        </a>
                    </li>
                }
                <li>
                    <a asp-controller="Account" asp-action="Login" class="nav-link text-white">
                        Logga in
                    </a>
                </li>
                <li>
                    <a asp-controller="Account" asp-action="Logout" class="nav-link text-white">
                        Logga ut
                    </a>
                </li>
                @*  <li>
                            <a asp-controller="Home" asp-action="Privacy" class="nav-link text-white">
                                Privacy
                            </a>
                        </li> *@

            </ul>

        </div>
    </div>

    <div class="mainContainer">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
