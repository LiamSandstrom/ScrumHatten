@{
    ViewData["Title"] = "Calender";
}

@section Styles {
    <style>
        .fc-event {
           border: none !important;
           padding: 2px 5px;
        }
        .fc-event-time, .fc-event-title {
         color: inherit !important; 
        }

        .fc-button-primary, .fc-customPlusButton-button {
            background-color: #006039 !important; 
            color: #A37E2C !important; 
            border-color: #A37E2C !important;
            text-transform: capitalize;
            opacity: 1 !important;
        }

        .fc-daygrid-dot-event {
            background-color: transparent !important;
        }

        .fc-daygrid-event-dot {
            border-color: #A37E2C !important;
        }

            .fc-button-primary:hover, .fc-customPlusButton-button:hover {
                background-color: #004b28 !important;
                color: #C1A05C !important;
            }
        .fc-button-active {
            background-color: #ffffff !important;
            color: #006039 !important;
            border-color: #006039 !important;
        }

        .fc-customPlusButton-button {
            font-weight: bold;
            font-size: 1.2em !important;
        }

        #calendar {
            margin-top: 20px;
            color: #333;
        }

        #btnDelete:hover {
        background-color: #600000 !important;
        color: #eeeeee !important;
        }

       .form-check-input { 
        border: 1px solid #006039 !important;
        background-color: #fff;
        }
        
        .form-check-input:checked {
            background-color: #006039 !important;
            border-color: #006039 !important;
        }

        .form-check-label {
            cursor: pointer;
            user-select: none;
        }
    </style>
}

<div id="calendar"></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script>
        var calendar;
        var currentEditId = null;
        var showAll = false; 

        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');
            var isAdmin = @User.IsInRole("Admin").ToString().ToLower();

            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: "sv",
                headerToolbar: {
                    left: 'prev,next today customPlusButton toggleAll',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                customButtons: {
                    customPlusButton: {
                        text: '+',
                        click: function () {
                            openModalForNew();
                        }
                    },
                    toggleAll: {
                        text: 'Visa allas schema',
                        click: function () {
                            showAll = !showAll; 
                            
                            var btn = document.querySelector('.fc-toggleAll-button');
                            if (showAll) {
                                btn.classList.add('active-toggle');
                                btn.innerText = 'Visar alla';
                            } else {
                                btn.classList.remove('active-toggle');
                                btn.innerText = 'Visa allas schema';
                            }
                            
                            calendar.refetchEvents(); 
                        }
                    }
                },
                events: function(fetchInfo, successCallback, failureCallback) {
                    var currentUserName = "@User.Identity.Name"; 

                    fetch('/Calendar/GetEvents?showAll=' + showAll)
                    .then(response => response.json())
                    .then(data => {
                        var processedEvents = data.map(function(ev) {
                            var eventOwner = (ev.userName || ev.ownerName || "").toLowerCase().trim();
                            var assignedTo = (ev.assignedToName || "").toLowerCase().trim();
                            var currentUser = currentUserName.toLowerCase().trim();

                            // Determine styling: if assignedTo is current user => dark green (mine)
                            // if assignedTo is someone else => brown (assigned to another)
                            // otherwise public/default => light green
                            if (assignedTo && assignedTo === currentUser) {
                                ev.backgroundColor = '#006039'; 
                                ev.borderColor = '#A37E2C';
                                ev.textColor = '#ffffff';
                            } else if (assignedTo && assignedTo !== currentUser) {
                                ev.backgroundColor = '#A37E2C';
                                ev.borderColor = '#663300';
                                ev.textColor = '#ffffff';
                            } else if (eventOwner === currentUser) {
                                ev.backgroundColor = '#006039'; 
                                ev.borderColor = '#A37E2C';
                                ev.textColor = '#ffffff';
                            } else {
                                ev.backgroundColor = '#90EE90'; 
                                ev.borderColor = '#7dcf7d';
                                ev.textColor = '#000000';
                            }

                            // Ensure title already includes order number (server may have prefixed it)
                            return ev;
                        });
                        successCallback(processedEvents);
                    })
                       .catch(error => {
                        failureCallback(error);
                    });
                },

        eventClick: function (info) {
        currentEditId = info.event.id;
        document.getElementById('eventTitle').value = info.event.title;
        if (info.event.start) {
        document.getElementById('eventDate').value = toLocalISOString(info.event.start);
        }
        if (info.event.end) {
        document.getElementById('eventEndDate').value = toLocalISOString(info.event.end);
        }
        else if (info.event.start) {
        var endDate = new Date(info.event.start.getTime() + 60 * 60000);
        document.getElementById('eventEndDate').value = toLocalISOString(endDate);
        }
        document.getElementById('btnDelete').style.display = 'block';
        document.getElementById('eventModalLabel').innerText = 'Redigera händelse';
        $('#eventModal').modal('show');
        },

        dateClick: function (info) {
        openModalForNew(info.dateStr + "T09:00");
        }
        });

        calendar.render();

        var targetSelect = document.getElementById('eventTarget');
        if (targetSelect && !isAdmin) {
        var otherOption = targetSelect.querySelector('option[value="other"]');
        if (otherOption) otherOption.remove();
        }

        $('#eventModal').on('show.bs.modal', function () {
        fetch('/Calendar/GetUsers')
        .then(res => res.json())
        .then(users => {
        var container = document.getElementById('userList');
        if (!container) return;
        container.innerHTML = users.map(u => `
        <div>
        <input type="checkbox" class="user-checkbox" value="${u.email}" />
        ${u.name} (${u.email})
        </div>
        `).join('');
        });
        });
        });

        function openModalForNew(dateStr = "") {
        currentEditId = null;
        document.getElementById('eventTitle').value = "";
        document.getElementById('eventOrder').value = "";
        fetch('/Calendar/GetMyOrders')
        .then(res => res.json())
        .then(orders => {
            var orderSelect = document.getElementById('eventOrder');
            orderSelect.innerHTML = '<option value="">-- Välj en order --</option>';
            
            orders.forEach(order => {
                var opt = document.createElement('option');
                opt.value = order.id;
                var cName = order.customerName ? " - " + order.customerName : "";
                opt.innerHTML = order.orderNumber + " - " + order.customerName;
                orderSelect.appendChild(opt);
            });
        });
        if (dateStr) document.getElementById('eventDate').value = dateStr;
        document.getElementById('btnDelete').style.display = 'none';
        document.getElementById('eventModalLabel').innerText = 'Lägg till händelse';
        $('#eventModal').modal('show');
        }

        function saveEvent() {
        var selectedUsers = Array.from(document.querySelectorAll('.user-checkbox:checked'))
        .map(cb => cb.value);

        var dateValue = document.getElementById('eventDate').value;
        var endDateValue = document.getElementById('eventEndDate').value;
        if (!dateValue) {
        alert('Vänligen ange ett datum och tid.');
        return;
        }

        var eventData = {
        id: currentEditId,
        title: document.getElementById('eventTitle').value,
        start: new Date(dateValue).toISOString(),
        end: new Date(endDateValue).toISOString(),
        targetType: document.getElementById('eventTarget').value,
        targetUserNames: selectedUsers,
        orderId: document.getElementById('eventOrder').value,
        color: "#006039" 
        };

        fetch('/Calendar/SaveEvent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(eventData)
        })
        .then(response => {
        if (response.ok) {
        $('#eventModal').modal('hide');
        calendar.refetchEvents();
        }
        });
        }

        function deleteEvent() {
        if (!currentEditId) return;
        if (confirm("Är du säker på att du vill ta bort denna händelse?")) {
        fetch('/Calendar/DeleteEvent/' + currentEditId, {
        method: 'DELETE'
        }).then(res => {
        if (res.ok) {
        $('#eventModal').modal('hide');
        calendar.refetchEvents();
        } else {
        alert("Kunde inte ta bort händelse.");
        }
        });
        }
        }

        function toLocalISOString(date) {
        var d = new Date(date);
        d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
        return d.toISOString().substring(0, 16);
        }
    </script>
}

<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="eventModalLabel">Lägg till händelse</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label>Titel</label>
                    <input type="text" id="eventTitle" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Starttid</label>
                    <input type="datetime-local" id="eventDate" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Sluttid</label>
                    <input type="datetime-local" id="eventEndDate" class="form-control" />
                </div>
                <div class="mb-3">
                 <label>Dina tilldelade ordrar (frivilligt)</label>
                  <select id="eventOrder" class="form-control">
                <option value="">-- Välj en order --</option>
                 </select>
                </div>
                <div class="mb-3">
                    <label>Vem ska se detta?</label>
                    <select id="eventTarget" class="form-control">
                        <option value="public">Alla</option>
                        <option value="private">Bara jag</option>
                        <option value="other">Specifik anställd</option>
                    </select>
                </div>
                <div id="userList" class="border p-2 rounded"></div>
            </div>
            <div class="modal-footer">
               <button type="button" id="btnDelete" class="btn" 
            style="display:none; background-color: #800000; color: white; border: none;" 
            onClick="deleteEvent()">Ta bort</button>
    
             <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Stäng</button>
    
             <button type="button" class="btn btn-primary" style="background-color: #006039; border-color: #A37E2C; color: #A37E2C;" 
             onClick="saveEvent()">Spara</button>
            </div>
        </div>
    </div>
</div>