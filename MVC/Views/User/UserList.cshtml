@model MVC.ViewModels.UserViewModel.UserListViewModel;
@{
}

<link rel="stylesheet" href="~/css/user.css"/>
<script src="~/js/user.js" defer></script>

<div class="pageContent">
    <div class="customerListHeader mt-5">
        <h1 class="userListHeaderTitle">Användare</h1>
        <input class="form-control" id="searchField" placeholder="Sök efter användare..." />
        <button class="btn btn-primary filterButton" type="button" data-bs-toggle="modal" data-bs-target="#filterModal" id="openFilterModelButton"><i class="bi bi-funnel"></i>Filtrera</button>
    </div>

    <!--Filter modal-->
    <form asp-action="FilteredUserList" method="get">
        <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="exampleModalLabel">Filtrera anställda</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
           
                        <div class="form-floating my-3">
                            <select asp-for="selectedRole" class="form-select" id="dropDownRole" asp-items="@(new SelectList(Model.allRoles))">
                                <option value="">Roll</option>
                            </select>
                            <label asp-for="selectedRole">Välj roll</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Stäng</button>
                        <a href="/User/UserList" class="btn btn-warning" id="clearButton">Rensa</a>
                       
                        <button type="submit" class="btn btn-primary">Filtrera</button>
                 
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="userTableContainer">
    <table class="table table-hover" id="personTable">
        <thead>
            <tr>
                <th scope="col"></th>
                <th scope="col">Namn</th>
                <th scope="col">E-mail</th>
                <th scope="col">Telefonnummer</th>
                <th scope="col">Roll</th>
                </tr>
        </thead>
        <tbody class="table-group-divider" id="tableBody">
            @for (
                
            int i = 0; i < Model.Users.Count; i++) {
                <tr class="tableRow">
                    <th class="tableCell" scope="row">@(i + 1)</th>
                    <td class="tableCell">@Model.Users[i].Name</td>
                    <td class="tableCell">@Model.Users[i].Email </td>
                    <td class="tableCell">@Model.Users[i].PhoneNumber</td>
                    @{
                            var roleId = Model.Users[i].Roles.FirstOrDefault();
                            var role = Model.UserRoles.FirstOrDefault(r => r.Id == roleId);
                            <td>@(role?.Name ?? "-")</td>
                        }
                        <td><a asp-action="Edit" asp-route-id="@Model.Users[i].Id">Redigera</a></td>
                    </tr>

            }
        </tbody>
    </table>
    </div>

</div>