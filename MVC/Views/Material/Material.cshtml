<h1>Material</h1>
<button type="button" class= "btn btn-primary" data-bs-toggle="modal" data-bs-target="#addMaterialModal">
    Lägg till nytt material
    </button>

<div class="modal fade" id="addMaterialModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nytt material</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addMaterialForm">
                    <div class="mb-3">
                        <label class="form-label" for="matName">Namn</label>
                        <input type="text" id="matName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="matUnit">Enhet</label>
                        <input type="text" id="matUnit" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="matPrice">Pris per enhet</label>
                        <input type="number" id="matPrice" class="form-control" step="0.01" min="0" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="matAmount">Antal</label>
                        <input type="number" id="matAmount" class="form-control" step="0.1" min="0"/>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Avbryt</button>
                <button type="button" class="btn btn-primary" onclick="saveMaterial()">Spara material</button>
            </div>
        </div>
    </div>

@section Scripts { 
    <script src="~/js/material.js"></script>
}

