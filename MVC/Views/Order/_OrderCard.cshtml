@model Models.Order

<div class="card mb-2 shadow-sm order-card border-start border-4 @(Model.Priority == Models.Priority.High ? "border-danger" : "border-info")" 
     data-id="@Model.Id" 
     style="cursor: pointer;">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="fw-bold mb-0">#@Model.Id.ToString().Substring(Math.Max(0, Model.Id.ToString().Length - 5))</h6>
            @if(Model.FastOrder) {
                <span class="badge bg-danger animate-pulse" style="font-size: 0.7rem;">PRIO</span>
            }
        </div>
        
        <div class="mb-2">
            <span class="text-success fw-bold fs-5">
                @Model.FinalPrice.ToString("C0", new System.Globalization.CultureInfo("sv-SE"))
            </span>
        </div>

        <div class="small mb-2 d-flex align-items-center">
            <i class="bi bi-person-circle me-1 text-muted"></i>
            @if (!string.IsNullOrEmpty(Model.MakerName))
            {
                <span class="fw-medium text-dark">@Model.MakerName</span>
            }
            else
            {
                <span class="text-muted fst-italic">Ej tilldelad</span>
            }
        </div>
        
        <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-2">
            <span class="small text-muted" style="font-size: 0.75rem;">📅 @Model.DateToFinish.ToShortDateString()</span>
            <span class="badge @(GetPriorityClass(Model.Priority))" style="font-size: 0.7rem;">@Model.Priority</span>
        </div>
    </div>
</div>

@functions {
    string GetPriorityClass(Models.Priority p) => p switch {
        Models.Priority.High => "bg-danger",
        Models.Priority.Medium => "bg-warning text-dark",
        Models.Priority.Low => "bg-info text-dark",
        _ => "bg-secondary"
    };
}