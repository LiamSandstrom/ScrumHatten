@model Models.Order

<div class="card mb-2 shadow-sm order-card border-start border-4 @(Model.Priority == Models.Priority.High ? "border-danger" : "border-info")" data-id="@Model.Id">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between">
            <h6 class="fw-bold">Order #@Model.Id</h6>
            @if(Model.FastOrder) {
                <span class="badge bg-danger animate-pulse">PRÖJSAD PRIO</span>
            }
        </div>
        
        <p class="small text-muted mb-2">Hattar: @Model.Hats.Count st</p>
        
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="small font-monospace">📅 @Model.DateToFinish.ToShortDateString()</span>
            <span class="badge @(GetPriorityClass(Model.Priority))">@Model.Priority</span>
        </div>
    </div>
</div>

@functions {
    string GetPriorityClass(Models.Priority p) => p switch {
        Models.Priority.High => "bg-danger",
        Models.Priority.Medium => "bg-warning text-dark",
        Models.Priority.Low => "bg-info text-dark"
    };
}