@using Models
@model List<Order>

@{
    ViewData["Title"] = "Orderhantering";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Produktionsflöde</h1>
        <span class="badge bg-dark">Totalt: @Model.Count ordrar</span>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header bg-warning text-dark fw-bold"> INKOMMANDE</div>
                <div class="card-body p-2 kanban-col" id="pending">
                    @foreach (var order in Model.Where(o => o.Status == Status.Pending))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header bg-primary text-white fw-bold"> PÅGÅENDE</div>
                <div class="card-body p-2 kanban-col" id="inprogress">
                    @foreach (var order in Model.Where(o => o.Status == Status.InProgress))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header bg-success text-white fw-bold"> KLARA</div>
                <div class="card-body p-2 kanban-col" id="completed">
                    @foreach (var order in Model.Where(o => o.Status == Status.Completed))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header bg-success text-white fw-bold"> Levererade</div>
                <div class="card-body p-2 kanban-col" id="delivered">
                    @foreach (var order in Model.Where(o => o.Status == Status.Delivered))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .kanban-col {
        min-height: 70vh;
        background-color: #f8f9fa;
        border-radius: 5px;
    }
    .order-card {
        transition: transform 0.2s;
    }
    .order-card:hover {
        transform: scale(1.02);
    }
</style>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    
    <script src="~/js/kanban.js"></script>
}