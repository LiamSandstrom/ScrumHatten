    @using Models
    @model MVC.ViewModels.OrderViewModel
    @{
        ViewData["Title"] = "Orderhantering";
    }
    <link rel="stylesheet" href="~/css/order.css" />

    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Orderöversikt</h1>
            <div style="display: flex; justify-content: center; align-items: center; gap: 8px;">
                <span class="badge bg-dark">Totalt: @Model.OrderList.Count ordrar</span>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createOrderModal">
                    Ny order
                </button>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="card bg-light border-0">
                    <div class="card-header custom-header-brown text-white fw-bold"> INKOMMANDE</div>
                    <div class="card-body p-2 kanban-col" id="pending">
                        @foreach (var order in Model.OrderList.Where(o => o.Status == Status.Pending))
                        {
                            @Html.Partial("_OrderCard", order)
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light border-0">
                    <div class="card-header custom-header-brown text-white fw-bold"> PÅGÅENDE</div>
                    <div class="card-body p-2 kanban-col" id="inprogress">
                        @foreach (var order in Model.OrderList.Where(o => o.Status == Status.InProgress))
                        {
                            @Html.Partial("_OrderCard", order)
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light border-0">
                    <div class="card-header custom-header-brown text-white fw-bold"> KLARA</div>
                    <div class="card-body p-2 kanban-col" id="completed">
                        @foreach (var order in Model.OrderList.Where(o => o.Status == Status.Completed))
                        {
                            @Html.Partial("_OrderCard", order)
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light border-0">
                    <div class="card-header custom-header-brown text-white fw-bold"> Levererade</div>
                    <div class="card-body p-2 kanban-col" id="delivered">
                        @foreach (var order in Model.OrderList.Where(o => o.Status == Status.Delivered))
                        {
                            @Html.Partial("_OrderCard", order)
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
<div class="modal fade" id="createOrderModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Ny order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="createOrderForm" enctype="multipart/form-data" method="post" action="/Order/Create">

                <div class="modal-body">

                    <!-- ===================== DETALJER ===================== -->
                    <div id="step1">
                    <button type="button" id="addHatBtn">Lägg till lagerförd</button>
                    <button type="button" id="addCustomHatBtn">Lägg till skräddarsydd</button>
                    <p id="error-rows" class="text-danger"></p>
                    <div id="rows">
<template id="customRowTemplate">
    <div class="row-item card mb-3 shadow-sm">
        <div class="card-body">

            <!-- Header -->
            <div class="d-flex justify-content-between mb-3">
                <h6 class="mb-0 fw-bold">Skräddarsydd hatt</h6>
                <button type="button" class="btn btn-sm btn-outline-danger remove-row">Ta bort</button>
            </div>

            <!-- Bild -->
            <p class="text-muted small text-uppercase fw-semibold mb-2">Bild</p>
            <div class="row g-3 mb-4 align-items-center" style="justify-content: space-around;">
                <div class="col-4 col-md-4">
                    <label class="form-label">Ladda upp bild</label>
                    <input type="file" accept="image/*" class="form-control custom-image" name="" />
                    <p class="text-muted small mt-1 mb-0">JPG, PNG eller WebP</p>
                </div>
                <div class="col-6 col-md-5">
                    <div class="border rounded p-2 d-flex align-items-center justify-content-center bg-light custom-preview-wrapper" style="min-height:120px;">
                        <span class="text-muted small custom-preview-placeholder">Ingen bild vald</span>
                        <img class="custom-preview rounded d-none" style="max-width:100%;object-fit:contain;" />
                    </div>
                </div>
            </div>

            <hr class="my-3" />

            <!-- Grundinfo -->
            <p class="text-muted small text-uppercase fw-semibold mb-2">Grundinfo</p>
            <div class="row g-3 mb-4">

                <div class="col-12 col-md-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Pris</label>
                            <div class="input-group">
                                <input type="number" min="0" step="50" class="form-control custom-price" name="" placeholder="0" />
                                <span class="input-group-text">kr</span>
                            </div>
                            <p class="error-text-field error-price"></p>
                        </div>
                        <div class="col-12" style="margin-top: 0;">
                            <label class="form-label">Antal</label>
                            <input type="number" min="1" value="1" class="form-control quantity-input" name="" />
                            <p class="error-text-field error-qty"></p>
                        </div>
                        <div class="col-12" style="margin-top: 0;">
                            <label class="form-label">Storlek</label>
                            <select class="form-select row-size" name="">
                                <option value="">Välj storlek</option>
                                <optgroup label="Barn">
                                    <option value="0-6m">0–6 månader (35–43 cm)</option>
                                    <option value="6-12m">6–12 månader (43–47 cm)</option>
                                    <option value="1-2y">1–2 år (48–50 cm)</option>
                                    <option value="2-4y">2–4 år (50–52 cm)</option>
                                    <option value="5-7y">5–7 år (52–54 cm)</option>
                                    <option value="8-12y">8–12 år (54–56 cm)</option>
                                </optgroup>
                                <optgroup label="Vuxen">
                                    <option value="S">S (55–56 cm)</option>
                                    <option value="M">M (57–58 cm)</option>
                                    <option value="L">L (59–60 cm)</option>
                                    <option value="XL">XL (61–62 cm)</option>
                                </optgroup>
                            </select>
                            <p class="error-text-field error-size"></p>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-8">
                    <label class="form-label">Beskrivning</label>
                    <textarea class="form-control custom-description" style="min-height: 90%; resize: none;" name="" placeholder="Beskriv hatten..."></textarea>
                </div>

            </div>

            <hr class="my-3" />

            <!-- Material -->
            <p class="text-muted small text-uppercase fw-semibold mb-2">Material</p>
            <p class="error-text-field error-materials"></p>
            <div class="material-list">
                <template class="material-row-template">
                    <div class="row material-row mt-2">
                        <input type="hidden" value="" />
                        <div class="col-md-7 mb-2 mb-md-0">
                            <label class="form-label-clean">Material</label>
                            <select name="" class="form-control materials-select"></select>
                            <p class="error-text-field error-material-u"></p>
                        </div>
                        <div class="col-md-3 mb-2 mb-md-0">
                            <label class="form-label-clean">Antal</label>
                            <input name="" type="number" value="1" min="1" class="form-control material-quantity" />
                            <p class="error-text-field error-material-qty"></p>
                        </div>
                        <div class="col-md-2 d-flex" style="align-items: center;">
                            <button type="button" class="btn btn-sm btn-outline-danger remove-material w-100">Ta bort</button>
                        </div>
                    </div>
                </template>
            </div>

        </div>
    </div>
</template>

<template id="rowTemplate">
    <div class="row-item card mb-3 shadow-sm">
        <div class="card-body">
            <div class="row g-3 align-items-center">

                <div class="col-12 col-sm-4 col-lg-2">
                    <label class="form-label">Hatt</label>
                    <select class="form-select hat-dropdown">
                        <option value="">Välj hatt</option>
                    </select>
                    <p class="error-text-field error-hat"></p>
                </div>

                <div class="col-6 col-sm-4 col-lg-1">
                    <label class="form-label">Antal</label>
                    <input type="number" min="1" value="1" class="form-control quantity-input" />
                    <p class="error-text-field error-qty"></p>
                </div>

                <div class="col-6 col-sm-4 col-lg-2">
                    <label class="form-label">Storlek</label>
                    <select class="form-select row-size" name="">
                        <option value="">Välj storlek</option>
                        <optgroup label="Barn">
                            <option value="0-6m">0–6 månader (35–43 cm)</option>
                            <option value="6-12m">6–12 månader (43–47 cm)</option>
                            <option value="1-2y">1–2 år (48–50 cm)</option>
                            <option value="2-4y">2–4 år (50–52 cm)</option>
                            <option value="5-7y">5–7 år (52–54 cm)</option>
                            <option value="8-12y">8–12 år (54–56 cm)</option>
                        </optgroup>
                        <optgroup label="Vuxen">
                            <option value="S">S (55–56 cm)</option>
                            <option value="M">M (57–58 cm)</option>
                            <option value="L">L (59–60 cm)</option>
                            <option value="XL">XL (61–62 cm)</option>
                        </optgroup>
                    </select>
                    <p class="error-text-field error-size"></p>
                </div>

                <div class="col-12 col-lg-7">
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <img class="hat-image rounded d-none" style="width:60px;height:60px;object-fit:contain;flex-shrink:0;" />
                        <div style="min-width:0;flex:1;">
                            <div class="fw-bold hat-name"></div>
                            <div class="text-muted small hat-description text-truncate"></div>
                            <div class="hat-price small text-muted"></div>
                            <div class="hat-quantity small text-muted"></div>
                            <div class="fw-bold text-primary hat-total"></div>
                        </div>
                        <button class="edit-btn btn btn-sm btn-secondary d-none" type="button">Ändra</button>
                        <button type="button" class="btn btn-sm btn-outline-danger remove-row">Ta bort</button>
                    </div>
                </div>

                <div class="material-list">
                    <template class="material-row-template">
                        <div class="row material-row">
                            <input type="hidden" value="" />
                            <div class="col-md-7 mb-2 mb-md-0">
                                <label class="form-label-clean">Material</label>
                                <select name="" class="form-control materials-select"></select>
                                <p class="error-text-field error-material-u"></p>
                            </div>
                            <div class="col-md-3 mb-2 mb-md-0">
                                <label class="form-label-clean">Antal</label>
                                <input name="" type="number" value="1" min="1" class="form-control material-quantity" />
                                <p class="error-text-field error-material-qty"></p>
                            </div>
                            <div class="col-md-2 d-flex" style="align-items: center;"> 
                                <button type="button" class="btn btn-sm btn-outline-danger remove-material w-100">Ta bort</button>
                            </div>
                        </div>
                    </template>
                </div>

            </div>
        </div>
    </div>
</template>
                    </div>

                    </div>

                    <div id="step2">

                    <div class="row mb-3 g-3">

                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-body">

                                    <h6 class="mb-3">Detaljer</h6>

                                    <div class="row g-3">

                                        <div class="col-12 col-sm-6">
                                            <label class="form-label">Transportkostnad</label>
                                            <div class="input-group">
                                                <input name="TransportPrice" class="form-control" type="number" min="0" step="10"
                                                       value="0" />
                                                <span class="input-group-text">kr</span>
                                            </div>
                                            <p id="error-TransportPrice" class="error-text"></p>
                                        </div>

                                        <div class="col-12 col-sm-6">
                                            <label class="form-label">Rabatt</label>
                                            <div class="input-group">
                                                <input name="Discount" class="form-control" type="number" min="0"
                                                       value="0" max="100" step="5" />
                                                <span class="input-group-text">Procent</span>
                                            </div>
                                            <p id="error-Discount" class="error-text"></p>
                                        </div>


                                        <div class="col-12 col-sm-6">
                                            <label class="form-label">Tid att utföra</label>
                                            <div class="input-group">
                                                <input name="TimeToMake" class="form-control" type="number" min="0"
                                                       value="0" />
                                                <span class="input-group-text">timmar</span>
                                            </div>
                                            <p id="error-TimeToMake" class="error-text"></p>
                                        </div>


                                        <div class="col-12 col-sm-6">
                                            <label class="form-label">Klart datum</label>
                                            <input name="DateToFinish" class="form-control" type="date"
                                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" 
                                                   style="height: 50%;"
                                                   />
                                            <p id="error-DateToFinish" class="error-text"></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===================== ORDER SUMMARY ===================== -->
                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-body">

                                    <h6 class="mb-3">Order översikt</h6>

                                    <div id="orderBreakdown" class="small text-muted"></div>

                                    <div class="mt-2 text-muted small fw-bold">Totalt</div>

                                    <div id="orderTotal" class="fs-4 fw-bold text-success">0 kr</div>

                                    <div class="form-check mt-3">
                                        <input name="FastOrder" id="fastOrder" class="form-check-input" type="checkbox"
                                               value="true" />
                                        <label class="form-check-label" for="FastOrder">Snabborder</label>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ===================== PERSONER ===================== -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="mb-3">Personer</h6>
                                    <div class="row g-3">
                                        <div class="col-12 col-sm-6">
                                            <label class="form-label">Utförare</label>
                                            @Html.DropDownListFor(
                                            m => m.SelectedUserId,
                                            Model.Users,
                                            "Välj Utförare",
                                            new { @class = "form-select" }
                                            )
                                            <p id="error-SelectedUserId" class="error-text"></p>
                                        </div>
                                        <div class="col-12 col-sm-6">
                                            <label class="form-label">Kund</label>
                                            @Html.DropDownListFor(
                                            m => m.SelectedCustomerId,
                                            Model.Customers,
                                            "Välj Kund",
                                            new { @class = "form-select" }
                                            )
                                            <p id="error-SelectedCustomerId" class="error-text"></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    </div>
                    <!-- GENERELLT FEL -->
                    <div id="formError" class="text-danger mt-3 d-none"></div>

                </div>

                <!-- ===================== KNAPPAR ===================== -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Avbryt</button>
                    <button type="button"id="prevBtn" class="btn btn-secondary" >Tillbaka</button>
                    <button type="button" id="nextBtn" class="btn btn-primary">Nästa</button>
                </div>

            </form>

        </div>
    </div>
</div>

<style>
    .custom-header-brown {
        background-color: #7d563b;
        !important;
        border-bottom: 2px solid #4E342E;
        text-align: center;
        letter-spacing: 1px;
    }

    .kanban-col {
        min-height: 70vh;
        background-color: #f4f1f0;
        border-radius: 5px;
    }

    .order-card {
        transition: transform 0.3s;
    }

    .order-card:hover {
        transform: scale(1.02);
    }

    h1 {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 1.5rem;
        color: #4E342E;
    }


    h1::after {
        content: "";
        display: block;
        width: 50px;
        height: 3px;
        background-color: #7d563b;
        margin-top: 5px;
        border-radius: 2px;
    }
</style>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script src="~/js/kanban.js"></script>
    <script src="~/js/order.js" asp-append-version="true" type="module"></script>
    <script>
        handleFormSubmit("createOrderForm");
    </script>
}

