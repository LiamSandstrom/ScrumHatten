@using Models
@model List<Order>

@{
    ViewData["Title"] = "Orderhantering";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Orderöversikt</h1>
        <span class="badge bg-dark">Totalt: @Model.Count ordrar</span>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header custom-header-brown text-white fw-bold"> INKOMMANDE</div>
                <div class="card-body p-2 kanban-col" id="pending">
                    @foreach (var order in Model.Where(o => o.Status == Status.Pending))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header custom-header-brown text-white fw-bold"> PÅGÅENDE</div>
                <div class="card-body p-2 kanban-col" id="inprogress">
                    @foreach (var order in Model.Where(o => o.Status == Status.InProgress))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header custom-header-brown text-white fw-bold"> KLARA</div>
                <div class="card-body p-2 kanban-col" id="completed">
                    @foreach (var order in Model.Where(o => o.Status == Status.Completed))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-light border-0">
                <div class="card-header custom-header-brown text-white fw-bold"> Levererade</div>
                <div class="card-body p-2 kanban-col" id="delivered">
                    @foreach (var order in Model.Where(o => o.Status == Status.Delivered))
                    {
                        @Html.Partial("_OrderCard", order)
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<style>

    .custom-header-brown {
        background-color: #7d563b; !important;
        border-bottom: 2px solid #4E342E;
        text-align: center;
        letter-spacing: 1px;
    }

    .kanban-col {
        min-height: 70vh;
        background-color: #f4f1f0;
        border-radius: 5px;
    }
    .order-card {
        transition: transform 0.3s;
    }
    .order-card:hover {
        transform: scale(1.02);
    }

    h1 {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 1.5rem;
        color: #4E342E; 
    }
    
   
    h1::after {
        content: "";
        display: block;
        width: 50px;
        height: 3px;
        background-color: #7d563b;
        margin-top: 5px;
        border-radius: 2px;
    }
</style>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    
    <script src="~/js/kanban.js"></script>
}
