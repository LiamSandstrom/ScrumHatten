    <style>
        .custom-header-brown {
            background-color: #7d563b !important;
            border-bottom: 2px solid #4E342E;
            text-align: center;
            letter-spacing: 1px;
        }

        .kanban-col {
            min-height: 70vh;
            background-color: #f4f1f0;
            border-radius: 5px;
        }

        .order-card {
            transition: transform 0.3s;
            cursor: pointer;
        }

        .order-card:hover {
            transform: scale(1.02);
