@model MVC.ViewModels.HatIndexViewModel
@using MVC.ViewModels

@{
    ViewData["Title"] = "Lagerförda hattar";

    var sizeOrder = new List<string>
    {
        "0–6 månader (35–43 cm)",
        "6–12 månader (43–47 cm)",
        "1–2 år (48–50 cm)",
        "2–4 år (50–52 cm)",
        "5–7 år (52–54 cm)",
        "8–12 år (54–56 cm)",
        "S (55–56 cm)",
        "M (57–58 cm)",
        "L (59–60 cm)",
        "XL (61–62 cm)"
    };
}

<style>
    body {
        background: #f8fafc;
    }

    .hat-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .btn-main,
    .clean-btn-primary {
        background: #006039;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.65rem 1rem;
        font-weight: 600;
    }

    .btn-main:hover,
    .clean-btn-primary:hover {
        background: #004b2c;
        color: white;
    }

    .hat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 6px 18px rgba(0,0,0,0.04);
        height: 100%;
    }

    .hat-card img {
        width: 100%;
        height: 160px;
        object-fit: contain;
        background: white;
        padding: 0.8rem;
    }

    .hat-body {
        padding: 0.9rem;
    }

    .hat-name {
        font-size: 1rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 0.4rem;
    }

    .hat-desc {
        font-size: 0.9rem;
        color: #6b7280;
        min-height: 32px;
        margin-bottom: 0.6rem;
    }

    .hat-price {
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 0.8rem;
    }

    .mini-link {
        background: transparent;
        border: none;
        padding: 0;
        color: #006039;
        font-weight: 600;
        font-size: 0.88rem;
        display: block;
        margin-bottom: 0.35rem;
        text-align: left;
    }

    .mini-link:hover {
        text-decoration: underline;
        color: #004b2c;
    }

    .action-row {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.8rem;
    }

    .btn-light-clean,
    .clean-btn-outline,
    .clean-btn-danger {
        border: 1px solid #d1d5db;
        background: white;
        color: #334155;
        border-radius: 10px;
        padding: 0.45rem 0.8rem;
        font-size: 0.88rem;
        font-weight: 500;
    }

    .btn-light-clean:hover,
    .clean-btn-outline:hover {
        background: #f8fafc;
        color: #111827;
    }

    .clean-btn-danger:hover {
        background: #fef2f2;
        color: #b91c1c;
        border-color: #fca5a5;
    }

    .clean-alert {
        border-radius: 12px;
    }

    .clean-modal .modal-content {
        border-radius: 18px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
    }

    .clean-modal .modal-header,
    .clean-modal .modal-footer {
        border-color: #f1f5f9;
    }

    .clean-modal .modal-title {
        font-weight: 700;
        color: #111827;
    }

    .form-label-clean {
        font-weight: 500;
        color: #374151;
        margin-bottom: 0.35rem;
    }

    .section-subtitle {
        font-size: 0.95rem;
        font-weight: 700;
        color: #334155;
        margin-bottom: 0.7rem;
    }

    .material-row {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.7rem 0.3rem;
        margin-bottom: 0.7rem;
    }

    .popup-list {
        padding-left: 1rem;
        margin-bottom: 0;
        color: #475569;
        font-size: 0.92rem;
    }

    .empty-state {
        text-align: center;
        padding: 2.5rem 1rem;
        border: 1px dashed #cbd5e1;
        border-radius: 16px;
        color: #64748b;
        background: white;
    }
</style>

<div class="hat-page">

    <div class="page-header">
        <h1 class="page-title">Lagerförda hattar</h1>

        <button class="btn-main"
                data-bs-toggle="modal"
                data-bs-target="#addHatModal">
            Lägg till hatt
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success clean-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger clean-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model == null || Model.Hats == null || !Model.Hats.Any())
    {
        <div class="empty-state">
            <h5 class="mb-2">Det finns inga hattar ännu</h5>
            <p class="mb-0">Börja med att lägga till en ny hatt.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var hat in Model.Hats)
            {
                var sortedSizes = hat.Sizes != null
                    ? hat.Sizes.OrderBy(s => sizeOrder.Contains(s.Label) ? sizeOrder.IndexOf(s.Label) : 999).ToList()
                    : null;

                <div class="col-sm-6 col-lg-4 col-xl-3 mb-4">
                    <div class="hat-card">
                        <img src="@(string.IsNullOrWhiteSpace(hat.ImageUrl) ? "/images/placeholder-hat.png" : hat.ImageUrl)"
                             alt="@hat.Name"
                             onerror="this.src='/images/placeholder-hat.png';" />

                        <div class="hat-body">
                            <div class="hat-name">@hat.Name</div>

                            <div class="hat-desc">
                                @{
                                    var beskrivning = string.IsNullOrWhiteSpace(hat.Description) ? "Ingen beskrivning ännu." : hat.Description;
                                    var kortBeskrivning = beskrivning.Length > 55 ? beskrivning.Substring(0, 55) + "..." : beskrivning;
                                }
                                @kortBeskrivning
                            </div>

                            <div class="hat-price">@hat.Price kr</div>

                            @if (hat.Sizes != null && hat.Sizes.Any())
                            {
                                <button type="button"
                                        class="mini-link"
                                        data-bs-toggle="modal"
                                        data-bs-target="#stockModal_@hat.Id">
                                    Visa lager →
                                </button>
                            }

                            @if (hat.Materials != null && hat.Materials.Any())
                            {
                                <button type="button"
                                        class="mini-link"
                                        data-bs-toggle="modal"
                                        data-bs-target="#materialModal_@hat.Id">
                                    Visa material →
                                </button>
                            }

                            <div class="action-row">
                                <button class="btn-light-clean"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editHatModal_@hat.Id">
                                    Redigera
                                </button>

                                <form asp-action="DeleteHat" method="post">
                                    <input type="hidden" name="id" value="@hat.Id" />
                                    <button type="submit"
                                            class="btn-light-clean clean-btn-danger"
                                            onclick="return confirm('Är du säker på att du vill ta bort hatten?')">
                                        Ta bort
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                @if (hat.Sizes != null && hat.Sizes.Any())
                {
                    <div class="modal fade clean-modal" id="stockModal_@hat.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">

                                <div class="modal-header">
                                    <h5 class="modal-title">Lager för @hat.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <ul class="popup-list">
                                        @foreach (var size in sortedSizes)
                                        {
                                            <li>@size.Quantity st @size.Label</li>
                                        }
                                    </ul>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="clean-btn-outline"
                                            data-bs-dismiss="modal">
                                        Stäng
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                }

                @if (hat.Materials != null && hat.Materials.Any())
                {
                    <div class="modal fade clean-modal" id="materialModal_@hat.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">

                                <div class="modal-header">
                                    <h5 class="modal-title">Material för @hat.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <ul class="popup-list">
                                        @foreach (var hm in hat.Materials)
                                        {
                                            var material = Model.Materials.FirstOrDefault(m => m.Id == hm.MaterialId);
                                            <li>
                                                @hm.Amount @(material != null ? material.Unit : "") @(material != null ? material.Name : "Okänt material")
                                            </li>
                                        }
                                    </ul>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="clean-btn-outline"
                                            data-bs-dismiss="modal">
                                        Stäng
                                    </button>
                                </div>

                            </div>
                        </div>
                    </div>
                }

                <div class="modal fade clean-modal" id="editHatModal_@hat.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">

                            <form asp-action="UpdateHat" method="post" enctype="multipart/form-data">
                                <div class="modal-header">
                                    <h5 class="modal-title">Ändra hatt</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <input type="hidden" name="Id" value="@hat.Id" />
                                    <input type="hidden" name="ImageUrl" value="@hat.ImageUrl" />

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Namn</label>
                                            <input name="Name" class="form-control" value="@hat.Name" required />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Pris(Kr)</label>
                                            <input name="Price" type="number" class="form-control" value="@hat.Price" required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label-clean">Beskrivning</label>
                                        <textarea name="Description" class="form-control">@hat.Description</textarea>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Byt bild</label>
                                            <input name="ImageFile" type="file" class="form-control" accept="image/*" />
                                        </div>
                                    </div>

                                    <hr />

                                    <div class="section-subtitle">Material per hatt</div>

                                    <div id="editMaterialRows_@hat.Id">
                                        @if (hat.Materials != null && hat.Materials.Any())
                                        {
                                            for (int i = 0; i < hat.Materials.Count; i++)
                                            {
                                                var hatMaterial = hat.Materials[i];

                                                <div class="row align-items-end material-row">
                                                    <input type="hidden" name="Materials.Index" value="@i" />

                                                    <div class="col-md-7 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Material</label>
                                                        <select name="Materials[@i].MaterialId" class="form-control" onchange="updateMaterialUnit(this)">
                                                            <option value="">-- Välj material --</option>
                                                            @foreach (var material in Model.Materials)
                                                            {
                                                                if (material.Id == hatMaterial.MaterialId)
                                                                {
                                                                    <option value="@material.Id" data-unit="@material.Unit" selected>@material.Name</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@material.Id" data-unit="@material.Unit">@material.Name</option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>

                                                    <div class="col-md-3 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Antal</label>
                                                        <input name="Materials[@i].Amount"
                                                               type="number"
                                                               min="1"
                                                               class="form-control"
                                                               value="@hatMaterial.Amount" />
                                                    </div>

                                                    <div class="col-md-2">
                                                        <button type="button"
                                                                class="clean-btn-danger w-100"
                                                                onclick="removeMaterialRow(this)">
                                                            Ta bort
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>

                                    <button type="button"
                                            class="clean-btn-outline mt-2"
                                            onclick="addEditMaterialRow('@hat.Id')">
                                        Lägg till material
                                    </button>

                                    <hr />

                                    <div class="section-subtitle">Storlekar</div>

                                    <div id="editSizeRows_@hat.Id">
                                        @if (hat.Sizes != null && hat.Sizes.Any())
                                        {
                                            for (int i = 0; i < hat.Sizes.Count; i++)
                                            {
                                                var size = hat.Sizes[i];

                                                <div class="row align-items-end material-row">
                                                    <input type="hidden" name="Sizes.Index" value="@i" />

                                                    <div class="col-md-6 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Storlek</label>
                                                        <select name="Sizes[@i].Label" class="form-control">
                                                            <option value="">-- Välj storlek --</option>
                                                            @foreach (var label in sizeOrder)
                                                            {
                                                                if (size.Label == label)
                                                                {
                                                                    <option value="@label" selected>@label</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@label">@label</option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>

                                                    <div class="col-md-4 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Antal i lager</label>
                                                        <input name="Sizes[@i].Quantity"
                                                               type="number"
                                                               min="0"
                                                               class="form-control"
                                                               value="@size.Quantity" />
                                                    </div>

                                                    <div class="col-md-2">
                                                        <button type="button"
                                                                class="clean-btn-danger w-100"
                                                                onclick="removeMaterialRow(this)">
                                                            Ta bort
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>

                                    <button type="button"
                                            class="clean-btn-outline mt-2"
                                            onclick="addEditSizeRow('@hat.Id')">
                                        Lägg till storlek
                                    </button>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="clean-btn-outline"
                                            data-bs-dismiss="modal">
                                        Avbryt
                                    </button>

                                    <button type="submit"
                                            class="clean-btn-primary">
                                        Spara ändringar
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade clean-modal" id="addHatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="AddHat" method="post" enctype="multipart/form-data">

                <div class="modal-header">
                    <h5 class="modal-title">Lägg till hatt</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label-clean">Namn</label>
                            <input name="Name" class="form-control" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label-clean">Pris(Kr)</label>
                            <input name="Price" type="number" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label-clean">Beskrivning</label>
                        <textarea name="Description" class="form-control"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label-clean">Bild</label>
                            <input name="ImageFile" type="file" class="form-control" accept="image/*" />
                        </div>
                    </div>

                    <hr />

                    <div class="section-subtitle">Material per hatt</div>

                    <div id="materialRows"></div>

                    <button type="button"
                            class="clean-btn-outline mt-2"
                            onclick="addMaterialRow()">
                        Lägg till material
                    </button>

                    <hr />

                    <div class="section-subtitle">Storlekar</div>

                    <div id="sizeRows"></div>

                    <button type="button"
                            class="clean-btn-outline mt-2"
                            onclick="addSizeRow()">
                        Lägg till storlek
                    </button>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="clean-btn-outline"
                            data-bs-dismiss="modal">
                        Avbryt
                    </button>

                    <button type="submit"
                            class="clean-btn-primary">
                        Spara hatt
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        let materialIndex = 0;
        let sizeIndex = 0;

        const materialOptions = `
            <option value="">-- Välj material --</option>
            @if (Model != null && Model.Materials != null)
            {
                foreach (var material in Model.Materials)
                {
                    <option value="@material.Id" data-unit="@material.Unit">@material.Name</option>
                }
            }
        `;

        const sizeOptions = `
            <option value="">-- Välj storlek --</option>
            @foreach (var label in sizeOrder)
            {
                <option value="@label">@label</option>
            }
        `;

        function addMaterialRow() {
            const container = document.getElementById("materialRows");
            const currentIndex = materialIndex;

            const row = document.createElement("div");
            row.className = "row align-items-end material-row";

            row.innerHTML = `
                <input type="hidden" name="Materials.Index" value="${currentIndex}" />

                <div class="col-md-7 mb-2 mb-md-0">
                    <label class="form-label-clean">Material</label>
                    <select name="Materials[${currentIndex}].MaterialId" class="form-control" onchange="updateMaterialUnit(this)">
                        ${materialOptions}
                    </select>
                </div>

                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="form-label-clean">Antal</label>
                    <input name="Materials[${currentIndex}].Amount"
                           type="number"
                           min="1"
                           class="form-control" />
                    <small class="material-unit text-muted"></small>
                </div>

                <div class="col-md-2">
                    <button type="button"
                            class="clean-btn-danger w-100"
                            onclick="removeMaterialRow(this)">
                        Ta bort
                    </button>
                </div>
            `;

            container.appendChild(row);
            materialIndex++;
        }

        function addSizeRow() {
            const container = document.getElementById("sizeRows");
            const currentIndex = sizeIndex;

            const row = document.createElement("div");
            row.className = "row align-items-end material-row";

            row.innerHTML = `
                <input type="hidden" name="Sizes.Index" value="${currentIndex}" />

                <div class="col-md-6 mb-2 mb-md-0">
                    <label class="form-label-clean">Storlek</label>
                    <select name="Sizes[${currentIndex}].Label" class="form-control">
                        ${sizeOptions}
                    </select>
                </div>

                <div class="col-md-4 mb-2 mb-md-0">
                    <label class="form-label-clean">Antal i lager</label>
                    <input name="Sizes[${currentIndex}].Quantity"
                           type="number"
                           min="0"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <button type="button"
                            class="clean-btn-danger w-100"
                            onclick="removeMaterialRow(this)">
                        Ta bort
                    </button>
                </div>
            `;

            container.appendChild(row);
            sizeIndex++;
        }

        function removeMaterialRow(button) {
            const row = button.closest(".material-row");
            if (row) {
                row.remove();
            }
        }

        function updateMaterialUnit(selectElement) {
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            const unit = selectedOption.getAttribute("data-unit") || "";
            const row = selectElement.closest(".material-row");
            const unitElement = row.querySelector(".material-unit");

            if (unitElement) {
                unitElement.textContent = unit ? `Enhet: ${unit}` : "";
            }
        }

        const editMaterialIndexes = {};

        function addEditMaterialRow(hatId) {
            const container = document.getElementById("editMaterialRows_" + hatId);

            if (!container) return;

            if (editMaterialIndexes[hatId] === undefined) {
                editMaterialIndexes[hatId] = container.querySelectorAll(".material-row").length;
            }

            const currentIndex = editMaterialIndexes[hatId];

            const row = document.createElement("div");
            row.className = "row align-items-end material-row";

            row.innerHTML = `
                <input type="hidden" name="Materials.Index" value="${currentIndex}" />

                <div class="col-md-7 mb-2 mb-md-0">
                    <label class="form-label-clean">Material</label>
                    <select name="Materials[${currentIndex}].MaterialId" class="form-control" onchange="updateMaterialUnit(this)">
                        ${materialOptions}
                    </select>
                </div>

                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="form-label-clean">Antal</label>
                    <input name="Materials[${currentIndex}].Amount"
                           type="number"
                           min="1"
                           class="form-control" />
                    <small class="material-unit text-muted"></small>
                </div>

                <div class="col-md-2">
                    <button type="button"
                            class="clean-btn-danger w-100"
                            onclick="removeMaterialRow(this)">
                        Ta bort
                    </button>
                </div>
            `;

            container.appendChild(row);
            editMaterialIndexes[hatId]++;
        }

        const editSizeIndexes = {};

        function addEditSizeRow(hatId) {
            const container = document.getElementById("editSizeRows_" + hatId);

            if (!container) return;

            if (editSizeIndexes[hatId] === undefined) {
                editSizeIndexes[hatId] = container.querySelectorAll(".material-row").length;
            }

            const currentIndex = editSizeIndexes[hatId];

            const row = document.createElement("div");
            row.className = "row align-items-end material-row";

            row.innerHTML = `
                <input type="hidden" name="Sizes.Index" value="${currentIndex}" />

                <div class="col-md-6 mb-2 mb-md-0">
                    <label class="form-label-clean">Storlek</label>
                    <select name="Sizes[${currentIndex}].Label" class="form-control">
                        ${sizeOptions}
                    </select>
                </div>

                <div class="col-md-4 mb-2 mb-md-0">
                    <label class="form-label-clean">Antal i lager</label>
                    <input name="Sizes[${currentIndex}].Quantity"
                           type="number"
                           min="0"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <button type="button"
                            class="clean-btn-danger w-100"
                            onclick="removeMaterialRow(this)">
                        Ta bort
                    </button>
                </div>
            `;

            container.appendChild(row);
            editSizeIndexes[hatId]++;
        }

        document.addEventListener("DOMContentLoaded", function () {
            addMaterialRow();
            addSizeRow();

            document.querySelectorAll('select[name$=".MaterialId"], select[name*="Materials["]').forEach(select => {
                updateMaterialUnit(select);
            });
        });

        const addHatModal = document.getElementById("addHatModal");
        if (addHatModal) {
            addHatModal.addEventListener("hidden.bs.modal", function () {
                const materialContainer = document.getElementById("materialRows");
                materialContainer.innerHTML = "";
                materialIndex = 0;
                addMaterialRow();

                const sizeContainer = document.getElementById("sizeRows");
                sizeContainer.innerHTML = "";
                sizeIndex = 0;
                addSizeRow();
            });
        }
    </script>
}