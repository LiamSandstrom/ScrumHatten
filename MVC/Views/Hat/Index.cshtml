@model MVC.ViewModels.HatIndexViewModel
@using MVC.ViewModels

@{
    ViewData["Title"] = "Lagerförda hattar";
}

<style>
    body {
        background: #f8fafc;
    }

    .hat-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .btn-main {
        background: #006039;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.75rem 1.2rem;
        font-weight: 600;
    }

        .btn-main:hover {
            background: #004b2c;
            color: white;
        }

    .hat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
        height: 100%;
    }

        .hat-card img {
            width: 100%;
            height: 220px;
            object-fit: contain;
            background: #ffffff;
            padding: 1rem;
        }

    .hat-body {
        padding: 1rem;
    }

    .hat-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 0.5rem;
    }

    .hat-desc {
        color: #6b7280;
        font-size: 0.92rem;
        margin-bottom: 0.8rem;
        min-height: 40px;
    }

    .hat-price {
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 1rem;
    }

    .mini-link {
        background: transparent;
        border: none;
        padding: 0;
        color: #006039;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 0.6rem;
    }

        .mini-link:hover {
            text-decoration: underline;
            color: #004b2c;
        }

    .action-row {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .btn-light-clean {
        border: 1px solid #d1d5db;
        background: white;
        border-radius: 10px;
        padding: 0.45rem 0.8rem;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .btn-delete:hover {
        background: #fef2f2;
        color: #b91c1c;
    }
</style>

<div class="hat-page">

    <div class="page-header">
        <h1 class="page-title">Lagerförda hattar</h1>

        <button class="btn-main"
                data-bs-toggle="modal"
                data-bs-target="#addHatModal">
            Lägg till hatt
        </button>
    </div>

    <div class="row">
        @foreach (var hat in Model.Hats)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="hat-card">
                    <img src="@(string.IsNullOrWhiteSpace(hat.ImageUrl) ? "/images/placeholder-hat.png" : hat.ImageUrl)"
                         alt="@hat.Name"
                         onerror="this.src='/images/placeholder-hat.png';" />

                    <div class="hat-body">
                        <div class="hat-name">@hat.Name</div>

                        <div class="hat-desc">
                            @(string.IsNullOrWhiteSpace(hat.Description)
                                ? "Ingen beskrivning ännu."
                                : hat.Description)
                        </div>

                        <div class="hat-price">@hat.Price kr</div>

                        @if (hat.Sizes != null && hat.Sizes.Any())
                        {
                            <button type="button"
                                    class="mini-link"
                                    data-bs-toggle="modal"
                                    data-bs-target="#stockModal_@hat.Id">
                                Visa lager →
                            </button>
                        }

                        @if (hat.Materials != null && hat.Materials.Any())
                        {
                            <button type="button"
                                    class="mini-link"
                                    data-bs-toggle="modal"
                                    data-bs-target="#materialModal_@hat.Id">
                                Visa material →
                            </button>
                        }

                        <div class="action-row">
                            <button class="btn-light-clean"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editHatModal_@hat.Id">
                                Redigera
                            </button>

                            <form asp-action="DeleteHat" method="post">
                                <input type="hidden" name="id" value="@hat.Id" />
                                <button type="submit"
                                        class="btn-light-clean btn-delete"
                                        onclick="return confirm('Är du säker?')">
                                    Ta bort
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

</div>

<!-- Behåll dina befintliga modaler för Add / Edit / Lager / Material under detta -->


<div class="hat-page">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title">Lagerförda hattar</h1>

        <button class="clean-btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addHatModal">
            Lägg till hatt
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success clean-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger clean-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model == null || !Model.Hats.Any())
    {
        <div class="empty-state">
            <h5 class="mb-2">Det finns inga hattar ännu</h5>
            <p class="mb-0">Börja med att lägga till en ny hatt.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var hat in Model.Hats)
            {
                var sizeOrder = new List<string>
                {
                    "0–6 månader (35–43 cm)",
                    "6–12 månader (43–47 cm)",
                    "1–2 år (48–50 cm)",
                    "2–4 år (50–52 cm)",
                    "5–7 år (52–54 cm)",
                    "8–12 år (54–56 cm)",
                    "S (55–56 cm)",
                    "M (57–58 cm)",
                    "L (59–60 cm)",
                    "XL (61–62 cm)"
                };

                var sortedSizes = hat.Sizes != null
                    ? hat.Sizes.OrderBy(s => sizeOrder.Contains(s.Label) ? sizeOrder.IndexOf(s.Label) : 999).ToList()
                    : null;

                <div class="col-sm-6 col-lg-4 col-xl-3 mb-4">
                    <div class="hat-card">
                        <img src="@(string.IsNullOrWhiteSpace(hat.ImageUrl) ? "/images/placeholder-hat.png" : hat.ImageUrl)"
                             alt="@hat.Name"
                             class="img-fluid"
                             onerror="this.src='/images/placeholder-hat.png';" />

                        <div class="hat-card-body">
                            <div class="hat-name">@hat.Name</div>

                            <div class="hat-description">
                                @{
                                    var beskrivning = string.IsNullOrWhiteSpace(hat.Description) ? "Ingen beskrivning ännu." : hat.Description;
                                    var kortBeskrivning = beskrivning.Length > 55 ? beskrivning.Substring(0, 55) + "..." : beskrivning;
                                }
                                @kortBeskrivning
                            </div>

                            <div class="hat-meta"><strong>Pris:</strong> @hat.Price kr</div>

                            @if (hat.Sizes != null && hat.Sizes.Any())
                            {
                                <div class="hat-material-box">
                                    <div class="hat-material-title">Lager</div>
                                    <button type="button"
                                            class="clean-btn-outline w-100"
                                            data-bs-toggle="modal"
                                            data-bs-target="#stockModal_@hat.Id">
                                        Visa lager
                                    </button>
                                </div>
                            }

                            @if (hat.Materials != null && hat.Materials.Any())
                            {
                                <div class="hat-material-box">
                                    <div class="hat-material-title">Material per hatt</div>
                                    <button type="button"
                                            class="clean-btn-outline w-100"
                                            data-bs-toggle="modal"
                                            data-bs-target="#materialModal_@hat.Id">
                                        Visa material
                                    </button>
                                </div>
                            }

                            <div class="d-flex gap-2">
                                <button class="clean-btn-outline"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editHatModal_@hat.Id">
                                    Redigera
                                </button>

                                <form asp-action="DeleteHat" method="post">
                                    <input type="hidden" name="id" value="@hat.Id" />

                                    <button type="submit"
                                            class="clean-btn-danger"
                                            onclick="return confirm('Är du säker på att du vill ta bort hatten?')">
                                        Ta bort
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                @if (hat.Sizes != null && hat.Sizes.Any())
                {
                    <div class="modal fade clean-modal" id="stockModal_@hat.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Lager för @hat.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <ul class="hat-material-list">
                                        @foreach (var size in sortedSizes)
                                        {
                                            <li>@size.Quantity st @size.Label</li>
                                        }
                                    </ul>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="clean-btn-outline"
                                            data-bs-dismiss="modal">
                                        Stäng
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (hat.Materials != null && hat.Materials.Any())
                {
                    <div class="modal fade clean-modal" id="materialModal_@hat.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Material för @hat.Name</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <ul class="hat-material-list">
                                        @foreach (var hm in hat.Materials)
                                        {
                                            var material = Model.Materials.FirstOrDefault(m => m.Id == hm.MaterialId);

                                            <li>
                                                @hm.Amount @(material != null ? material.Unit : "") @(material != null ? material.Name : "Okänt material")
                                            </li>
                                        }
                                    </ul>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="clean-btn-outline"
                                            data-bs-dismiss="modal">
                                        Stäng
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="modal fade clean-modal" id="editHatModal_@hat.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">

                            <form asp-action="UpdateHat" method="post" enctype="multipart/form-data">
                                <div class="modal-header">
                                    <h5 class="modal-title">Ändra hatt</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <input type="hidden" name="Id" value="@hat.Id" />
                                    <input type="hidden" name="ImageUrl" value="@hat.ImageUrl" />

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Namn</label>
                                            <input name="Name" class="form-control" value="@hat.Name" required />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Pris(Kr)</label>
                                            <input name="Price" type="number" class="form-control" value="@hat.Price" required />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label-clean">Beskrivning</label>
                                        <textarea name="Description" class="form-control">@hat.Description</textarea>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Byt bild</label>
                                            <input name="ImageFile" type="file" class="form-control" accept="image/*" />
                                        </div>
                                    </div>

                                    <hr />

                                    <div class="section-subtitle">Material per hatt</div>

                                    <div id="editMaterialRows_@hat.Id">
                                        @if (hat.Materials != null && hat.Materials.Any())
                                        {
                                            for (int i = 0; i < hat.Materials.Count; i++)
                                            {
                                                var hatMaterial = hat.Materials[i];

                                                <div class="row align-items-end material-row">
                                                    <input type="hidden" name="Materials.Index" value="@i" />

                                                    <div class="col-md-7 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Material</label>
                                                        <select name="Materials[@i].MaterialId" class="form-control" onchange="updateMaterialUnit(this)">
                                                            <option value="">-- Välj material --</option>
                                                            @foreach (var material in Model.Materials)
                                                            {
                                                                if (material.Id == hatMaterial.MaterialId)
                                                                {
                                                                    <option value="@material.Id" data-unit="@material.Unit" selected>@material.Name</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@material.Id" data-unit="@material.Unit">@material.Name</option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>

                                                    <div class="col-md-3 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Antal</label>
                                                        <input name="Materials[@i].Amount"
                                                               type="number"
                                                               min="1"
                                                               class="form-control"
                                                               value="@hatMaterial.Amount" />
                                                    </div>

                                                    <div class="col-md-2">
                                                        <button type="button"
                                                                class="clean-btn-danger w-100"
                                                                onclick="removeMaterialRow(this)">
                                                            Ta bort
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>

                                    <button type="button"
                                            class="clean-btn-outline mt-2"
                                            onclick="addEditMaterialRow('@hat.Id')">
                                        Lägg till material
                                    </button>

                                    <hr />

                                    <div class="section-subtitle">Storlekar</div>

                                    <div id="editSizeRows_@hat.Id">
                                        @if (hat.Sizes != null && hat.Sizes.Any())
                                        {
                                            for (int i = 0; i < hat.Sizes.Count; i++)
                                            {
                                                var size = hat.Sizes[i];

                                                <div class="row align-items-end material-row">
                                                    <input type="hidden" name="Sizes.Index" value="@i" />

                                                    <div class="col-md-6 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Storlek</label>
                                                        <select name="Sizes[@i].Label" class="form-control">
                                                            <option value="">-- Välj storlek --</option>
                                                            <option value="0–6 månader (35–43 cm)" selected="@(size.Label == "0–6 månader (35–43 cm)")">0–6 månader (35–43 cm)</option>
                                                            <option value="6–12 månader (43–47 cm)" selected="@(size.Label == "6–12 månader (43–47 cm)")">6–12 månader (43–47 cm)</option>
                                                            <option value="1–2 år (48–50 cm)" selected="@(size.Label == "1–2 år (48–50 cm)")">1–2 år (48–50 cm)</option>
                                                            <option value="2–4 år (50–52 cm)" selected="@(size.Label == "2–4 år (50–52 cm)")">2–4 år (50–52 cm)</option>
                                                            <option value="5–7 år (52–54 cm)" selected="@(size.Label == "5–7 år (52–54 cm)")">5–7 år (52–54 cm)</option>
                                                            <option value="8–12 år (54–56 cm)" selected="@(size.Label == "8–12 år (54–56 cm)")">8–12 år (54–56 cm)</option>
                                                            <option value="S (55–56 cm)" selected="@(size.Label == "S (55–56 cm)")">S (55–56 cm)</option>
                                                            <option value="M (57–58 cm)" selected="@(size.Label == "M (57–58 cm)")">M (57–58 cm)</option>
                                                            <option value="L (59–60 cm)" selected="@(size.Label == "L (59–60 cm)")">L (59–60 cm)</option>
                                                            <option value="XL (61–62 cm)" selected="@(size.Label == "XL (61–62 cm)")">XL (61–62 cm)</option>
                                                        </select>
                                                    </div>

                                                    <div class="col-md-4 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Antal i lager</label>
                                                        <input name="Sizes[@i].Quantity"
                                                               type="number"
                                                               min="0"
                                                               class="form-control"
                                                               value="@size.Quantity" />
                                                    </div>

                                                    <div class="col-md-2">
                                                        <button type="button"
                                                                class="clean-btn-danger w-100"
                                                                onclick="removeMaterialRow(this)">
                                                            Ta bort
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>

                                    <button type="button"
                                            class="clean-btn-outline mt-2"
                                            onclick="addEditSizeRow('@hat.Id')">
                                        Lägg till storlek
                                    </button>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="clean-btn-outline"
                                            data-bs-dismiss="modal">
                                        Avbryt
                                    </button>

                                    <button type="submit"
                                            class="clean-btn-primary">
                                        Spara ändringar
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>