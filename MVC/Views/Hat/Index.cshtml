@model MVC.ViewModels.HatIndexViewModel
@using MVC.ViewModels

@{
    ViewData["Title"] = "Alla hattar";
}

<style>
    /* =========================================
       SIDANS YTTRE LAYOUT
    ========================================= */
    .hat-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 0;
    }

    /* =========================================
       KNAPPAR
    ========================================= */
    .clean-btn-primary {
        background-color: #2563eb;
        border: 1px solid #2563eb;
        color: white;
        border-radius: 10px;
        padding: 0.55rem 1rem;
        font-weight: 600;
        font-size: 0.92rem;
        box-shadow: 0 4px 10px rgba(37, 99, 235, 0.22);
        transition: background-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }

    .clean-btn-primary:hover {
        background-color: #1d4ed8;
        border-color: #1d4ed8;
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 6px 14px rgba(37, 99, 235, 0.28);
    }

    .clean-btn-outline {
        background-color: white;
        border: 1px solid #cbd5e1;
        color: #334155;
        border-radius: 8px;
        padding: 0.4rem 0.8rem;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .clean-btn-outline:hover {
        background-color: #f8fafc;
        border-color: #94a3b8;
        color: #0f172a;
    }

    .clean-btn-danger {
        background-color: white;
        border: 1px solid #e2e8f0;
        color: #475569;
        border-radius: 8px;
        padding: 0.4rem 0.8rem;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .clean-btn-danger:hover {
        background-color: #fef2f2;
        border-color: #fca5a5;
        color: #b91c1c;
    }

    /* =========================================
       HATTKORT
    ========================================= */
    .hat-card {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        background: white;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.04);
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        height: 100%;
    }

    .hat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.07);
    }

    .hat-card img {
        height: 180px;
        object-fit: contain;
        width: 100%;
    }

    .hat-card-body {
        padding: 0.85rem;
    }

    .hat-name {
        font-size: 1rem;
        font-weight: 600;
        color: #111827;
        margin-bottom: 0.35rem;
    }

    .hat-description {
        color: #6b7280;
        margin-bottom: 0.7rem;
        min-height: 38px;
        font-size: 0.9rem;
        line-height: 1.35;
    }

    .hat-meta {
        color: #374151;
        margin-bottom: 0.2rem;
        font-size: 0.9rem;
    }

    /* =========================================
       MATERIALRUTA I HATTKORT
    ========================================= */
    .hat-material-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.55rem 0.65rem;
        margin-top: 0.7rem;
        margin-bottom: 0.8rem;
    }

    .hat-material-title {
        font-weight: 600;
        color: #334155;
        margin-bottom: 0.25rem;
        font-size: 0.85rem;
    }

    .hat-material-list {
        padding-left: 1rem;
        margin-bottom: 0;
        color: #475569;
        font-size: 0.84rem;
    }

    /* =========================================
       ALERTS & MODALS
    ========================================= */
    .clean-alert {
        border-radius: 12px;
        border: 1px solid transparent;
    }

    .clean-modal .modal-content {
        border-radius: 18px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
    }

    .clean-modal .modal-header,
    .clean-modal .modal-footer {
        border-color: #f1f5f9;
    }

    .clean-modal .modal-title {
        font-weight: 600;
        color: #111827;
    }

    /* =========================================
       FORMULÄR
    ========================================= */
    .form-label-clean {
        font-weight: 500;
        color: #374151;
        margin-bottom: 0.35rem;
    }

    .section-subtitle {
        font-size: 0.95rem;
        font-weight: 600;
        color: #334155;
        margin-bottom: 0.7rem;
    }

    .material-row {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.7rem 0.3rem;
        margin-bottom: 0.7rem;
    }

    /* =========================================
       TOMT LÄGE
    ========================================= */
    .empty-state {
        text-align: center;
        padding: 2.5rem 1rem;
        border: 1px dashed #cbd5e1;
        border-radius: 16px;
        color: #64748b;
        background: #f8fafc;
    }
</style>

<div class="hat-page">

    <!-- =========================================
         SIDHUVUD
    ========================================= -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title">Alla hattar</h1>

        <button class="clean-btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addHatModal">
            Lägg till hatt
        </button>
    </div>

    <!-- =========================================
         FEEDBACKMEDDELANDEN
    ========================================= -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success clean-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger clean-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- =========================================
         OM DET INTE FINNS NÅGRA HATTAR
    ========================================= -->
    @if (Model == null || !Model.Hats.Any())
    {
        <div class="empty-state">
            <h5 class="mb-2">Det finns inga hattar ännu</h5>
            <p class="mb-0">Börja med att lägga till en ny hatt.</p>
        </div>
    }
    else
    {
        <!-- =========================================
             LISTA MED ALLA HATTAR
        ========================================= -->
        <div class="row">
            @foreach (var hat in Model.Hats)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3 mb-4">
                    <div class="hat-card">
                        <img src="@(string.IsNullOrWhiteSpace(hat.ImageUrl) ? "/images/placeholder-hat.png" : hat.ImageUrl)"
                             alt="@hat.Name"
                             class="img-fluid"
                             onerror="this.src='/images/placeholder-hat.png';" />

                        <div class="hat-card-body">

                            <!-- Hattnamn -->
                            <div class="hat-name">@hat.Name</div>

                            <!-- Kort beskrivning -->
                            <div class="hat-description">
                                @{
                                    var beskrivning = string.IsNullOrWhiteSpace(hat.Description) ? "Ingen beskrivning ännu." : hat.Description;
                                    var kortBeskrivning = beskrivning.Length > 55 ? beskrivning.Substring(0, 55) + "..." : beskrivning;
                                }
                                @kortBeskrivning
                            </div>

                            <!-- Pris och lagerstatus -->
                            <div class="hat-meta"><strong>Pris:</strong> @hat.Price kr</div>
                            <div class="hat-meta"><strong>I lager:</strong> @hat.Quantity</div>

                            @if (hat.Sizes != null && hat.Sizes.Any())
{
    <div class="hat-material-box">
        <div class="hat-material-title">Storlekar</div>
        <ul class="hat-material-list">
            @foreach (var size in hat.Sizes)
            {
                <li>@size.Quantity st @size.Label</li>
            }
        </ul>
    </div>
}

                            <!-- Materiallista -->
                            @if (hat.Materials != null && hat.Materials.Any())
                            {
                                <div class="hat-material-box">
                                    <div class="hat-material-title">Material per hatt</div>
                                    <ul class="hat-material-list">
                                        @foreach (var hm in hat.Materials)
                                        {
                                            var material = Model.Materials.FirstOrDefault(m => m.Id == hm.MaterialId);
                                            <li>
                                                @hm.Amount @(material != null ? material.Unit : "") @(material != null ? material.Name : "Okänt material")
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }

                            <!-- Knappar för redigera / ta bort -->
                            <div class="d-flex gap-2">
                                <button class="clean-btn-outline"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editHatModal_@hat.Id">
                                    Redigera
                                </button>

                                <form asp-action="DeleteHat" method="post">
                                    <input type="hidden" name="id" value="@hat.Id" />

                                    <button type="submit"
                                            class="clean-btn-danger"
                                            onclick="return confirm('Är du säker på att du vill ta bort hatten?')">
                                        Ta bort
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- =========================================
                     MODAL: REDIGERA BEFINTLIG HATT
                ========================================= -->
                <div class="modal fade clean-modal" id="editHatModal_@hat.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">

                            <form asp-action="UpdateHat" method="post" enctype="multipart/form-data">
                                <div class="modal-header">
                                    <h5 class="modal-title">Ändra hatt</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    <!-- Dolda fält -->
                                    <input type="hidden" name="Id" value="@hat.Id" />
                                    <input type="hidden" name="ImageUrl" value="@hat.ImageUrl" />

                                    <!-- Grundinfo -->
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Namn</label>
                                            <input name="Name" class="form-control" value="@hat.Name" required />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Pris(Kr)</label>
                                            <input name="Price" type="number" class="form-control" value="@hat.Price" required />
                                        </div>
                                    </div>

                                    <!-- Beskrivning -->
                                    <div class="mb-3">
                                        <label class="form-label-clean">Beskrivning</label>
                                        <textarea name="Description" class="form-control">@hat.Description</textarea>
                                    </div>

                                    <!-- Bild + lager -->
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Byt bild</label>
                                            <input name="ImageFile" type="file" class="form-control" accept="image/*" />
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label class="form-label-clean">Antal i lager</label>
                                            <input name="Quantity" type="number" class="form-control" value="@hat.Quantity" required />
                                        </div>
                                    </div>

                                    <hr />

                                    <!-- Material -->
                                    <div class="section-subtitle">Material per hatt</div>

                                    <div id="editMaterialRows_@hat.Id">
                                        @if (hat.Materials != null && hat.Materials.Any())
                                        {
                                            for (int i = 0; i < hat.Materials.Count; i++)
                                            {
                                                var hatMaterial = hat.Materials[i];

                                                <div class="row align-items-end material-row">
                                                    <input type="hidden" name="Materials.Index" value="@i" />

                                                    <div class="col-md-7 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Material</label>
                                                        <select name="Materials[@i].MaterialId" class="form-control" onchange="updateMaterialUnit(this)">
                                                            <option value="">-- Välj material --</option>
                                                            @foreach (var material in Model.Materials)
                                                            {
                                                                if (material.Id == hatMaterial.MaterialId)
                                                                {
                                                                    <option value="@material.Id" data-unit="@material.Unit" selected>@material.Name</option>
                                                                }
                                                                else
                                                                {
                                                                    <option value="@material.Id" data-unit="@material.Unit">@material.Name</option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>

                                                    <div class="col-md-3 mb-2 mb-md-0">
                                                        <label class="form-label-clean">Antal</label>
                                                        <input name="Materials[@i].Amount"
                                                               type="number"
                                                               min="1"
                                                               class="form-control"
                                                               value="@hatMaterial.Amount" />
                                                    </div>

                                                    <div class="col-md-2">
                                                        <button type="button"
                                                                class="clean-btn-danger w-100"
                                                                onclick="removeMaterialRow(this)">
                                                            Ta bort
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>

                                    <button type="button"
                                            class="clean-btn-outline mt-2"
                                            onclick="addEditMaterialRow('@hat.Id')">
                                        Lägg till material
                                    </button>
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="clean-btn-outline"
                                            data-bs-dismiss="modal">
                                        Avbryt
                                    </button>

                                    <button type="submit"
                                            class="clean-btn-primary">
                                        Spara ändringar
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- =========================================
     MODAL: LÄGG TILL NY HATT
========================================= -->
<div class="modal fade clean-modal" id="addHatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="AddHat" method="post" enctype="multipart/form-data">

                <div class="modal-header">
                    <h5 class="modal-title">Lägg till hatt</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <!-- Grundinfo -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label-clean">Namn</label>
                            <input name="Name" class="form-control" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label-clean">Pris(Kr)</label>
                            <input name="Price" type="number" class="form-control" required />
                        </div>
                    </div>

                    <!-- Beskrivning -->
                    <div class="mb-3">
                        <label class="form-label-clean">Beskrivning</label>
                        <textarea name="Description" class="form-control"></textarea>
                    </div>

                    <!-- Bild + lager -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label-clean">Bild</label>
                            <input name="ImageFile" type="file" class="form-control" accept="image/*" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label-clean">Antal i lager</label>
                            <input name="Quantity" type="number" class="form-control" required />
                        </div>
                    </div>

                    <hr />

                    <!-- Material -->
                    <div class="section-subtitle">Material per hatt</div>

                    <div id="materialRows"></div>

                    <button type="button"
                            class="clean-btn-outline mt-2"
                            onclick="addMaterialRow()">
                        Lägg till material
                    </button>
                    <hr />

                        <div class="section-subtitle">Storlekar</div>

                        <div id="sizeRows"></div>

                        <button type="button"
                        class="clean-btn-outline mt-2"
                        onclick="addSizeRow()">
                        Lägg till storlek
                        </button>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="clean-btn-outline"
                            data-bs-dismiss="modal">
                        Avbryt
                    </button>

                    <button type="submit"
                            class="clean-btn-primary">
                        Spara hatt
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        /* =========================================
           GLOBALT INDEX FÖR NYA MATERIALRADER
        ========================================= */
        let materialIndex = 0;
        let sizeIndex = 0;

        /* =========================================
           HTML-ALTERNATIV FÖR MATERIAL-DROPDOWN
        ========================================= */
        const materialOptions = `
            <option value="">-- Välj material --</option>
            @foreach (var material in Model.Materials)
            {
                <option value="@material.Id" data-unit="@material.Unit">@material.Name</option>
            }
        `;

            /* =========================================
               LÄGG TILL MATERIALRAD I "LÄGG TILL HATT"
            ========================================= */
            function addMaterialRow() {
                const container = document.getElementById("materialRows");
                const currentIndex = materialIndex;

                const row = document.createElement("div");
                row.className = "row align-items-end material-row";

                row.innerHTML = `
                        <input type="hidden" name="Materials.Index" value="${currentIndex}" />

                        <div class="col-md-7 mb-2 mb-md-0">
                            <label class="form-label-clean">Material</label>
                            <select name="Materials[${currentIndex}].MaterialId" class="form-control" onchange="updateMaterialUnit(this)">
                                ${materialOptions}
                            </select>
                        </div>

                        <div class="col-md-3 mb-2 mb-md-0">
                            <label class="form-label-clean">Antal</label>
                            <input name="Materials[${currentIndex}].Amount"
                                   type="number"
                                   min="1"
                                   class="form-control" />
                                   <small class="material-unit text-muted"></small>
                        </div>

                        <div class="col-md-2">
                            <button type="button"
                                    class="clean-btn-danger w-100"
                                    onclick="removeMaterialRow(this)">
                                Ta bort
                            </button>
                        </div>
                    `;

                container.appendChild(row);
                materialIndex++;
            }

            function addSizeRow() {
    const container = document.getElementById("sizeRows");
    const currentIndex = sizeIndex;

    const row = document.createElement("div");
    row.className = "row align-items-end material-row";

    row.innerHTML = `
        <input type="hidden" name="Sizes.Index" value="${currentIndex}" />

        <div class="col-md-6 mb-2 mb-md-0">
            <label class="form-label-clean">Storlek</label>
            <select name="Sizes[${currentIndex}].Label" class="form-control">
                <option value="">-- Välj storlek --</option>
                <option value="0–6 månader (35–43 cm)">0–6 månader (35–43 cm)</option>
                <option value="6–12 månader (43–47 cm)">6–12 månader (43–47 cm)</option>
                <option value="1–2 år (48–50 cm)">1–2 år (48–50 cm)</option>
                <option value="2–4 år (50–52 cm)">2–4 år (50–52 cm)</option>
                <option value="5–7 år (52–54 cm)">5–7 år (52–54 cm)</option>
                <option value="8–12 år (54–56 cm)">8–12 år (54–56 cm)</option>
                <option value="S (55–56 cm)">S (55–56 cm)</option>
                <option value="M (57–58 cm)">M (57–58 cm)</option>
                <option value="L (59–60 cm)">L (59–60 cm)</option>
                <option value="XL (61–62 cm)">XL (61–62 cm)</option>
            </select>
        </div>

        <div class="col-md-4 mb-2 mb-md-0">
            <label class="form-label-clean">Antal i lager</label>
            <input name="Sizes[${currentIndex}].Quantity"
                   type="number"
                   min="0"
                   class="form-control" />
        </div>

        <div class="col-md-2">
            <button type="button"
                    class="clean-btn-danger w-100"
                    onclick="removeMaterialRow(this)">
                Ta bort
            </button>
        </div>
    `;

    container.appendChild(row);
    sizeIndex++;
}

            /* =========================================
               TA BORT EN MATERIALRAD
            ========================================= */
            function removeMaterialRow(button) {
                const row = button.closest(".material-row");
                if (row) {
                    row.remove();
                }
            }

            function updateMaterialUnit(selectElement) {
                const selectedOption = selectElement.options[selectElement.selectedIndex];
                const unit = selectedOption.getAttribute("data-unit") || "";
                const row = selectElement.closest(".material-row");
                const unitElement = row.querySelector(".material-unit");

                if (unitElement) {
                    unitElement.textContent = unit ? `Enhet: ${unit}` : "";
                }
            }

            /* =========================================
               HÅLLA REDA PÅ INDEX FÖR REDIGERINGSMODALER
        ========================================= */
        const editMaterialIndexes = {};

        /* =========================================
           LÄGG TILL MATERIALRAD I "REDIGERA HATT"
        ========================================= */
        function addEditMaterialRow(hatId) {
            const container = document.getElementById("editMaterialRows_" + hatId);

            if (!container) return;

            if (editMaterialIndexes[hatId] === undefined) {
                editMaterialIndexes[hatId] = container.querySelectorAll(".material-row").length;
            }

            const currentIndex = editMaterialIndexes[hatId];

            const row = document.createElement("div");
            row.className = "row align-items-end material-row";

            row.innerHTML = `
                <input type="hidden" name="Materials.Index" value="${currentIndex}" />

                <div class="col-md-7 mb-2 mb-md-0">
                    <label class="form-label-clean">Material</label>
                    <select name="Materials[${currentIndex}].MaterialId" class="form-control" onchange="updateMaterialUnit(this)">
                        ${materialOptions}
                    </select>
                </div>

                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="form-label-clean">Antal</label>
                    <input name="Materials[${currentIndex}].Amount"
                           type="number"
                           min="1"
                           class="form-control" />
                           <small class="material-unit text-muted"></small>
                </div>

                <div class="col-md-2">
                    <button type="button"
                            class="clean-btn-danger w-100"
                            onclick="removeMaterialRow(this)">
                        Ta bort
                    </button>
                </div>
            `;

            container.appendChild(row);
            editMaterialIndexes[hatId]++;
        }

        /* =========================================
           LÄGG TILL EN TOM MATERIALRAD NÄR SIDAN LADDAS
        ========================================= */
        document.addEventListener("DOMContentLoaded", function () {
        addMaterialRow();
        addSizeRow();

        document.querySelectorAll('select[name$=".MaterialId"], select[name*="Materials["]').forEach(select => {
        updateMaterialUnit(select);
            });
        });

        /* =========================================
           ÅTERSTÄLL "LÄGG TILL HATT"-MODALEN NÄR DEN STÄNGS
        ========================================= */
        const addHatModal = document.getElementById("addHatModal");
        if (addHatModal) {
            addHatModal.addEventListener("hidden.bs.modal", function () {
                const container = document.getElementById("materialRows");
                container.innerHTML = "";
                materialIndex = 0;
                addMaterialRow();

                const sizeContainer = document.getElementById("sizeRows");
                sizeContainer.innerHTML = "";
                sizeIndex = 0;
                addSizeRow();
            });
        }
    </script>
}