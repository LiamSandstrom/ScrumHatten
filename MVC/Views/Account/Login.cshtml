@model MVC.ViewModels.Account.LoginViewModel;
@section Scripts {
    <script>
        handleFormSubmit("loginForm")
    </script>
    }

<link rel="stylesheet" href="~/css/login.css/">
<div class="loginContainer">
    <form asp-action="Login" method="post" id="loginForm">
        <h1 class="h3 mb-3 fw-normal">Logga in</h1>

        <div class="form-floating mb-2">
            <input asp-for="Email" type="email" class="form-control" id="floatingInput" placeholder="namn@exempel.com">
            <label for="floatingInput">Email</label>
            <p id="error-Email" class="error-text"></p>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Lösenord">
            <label for="floatingPassword">Lösenord</label>
            <p id="error-Password" class="error-text"></p>
        </div>

        <div class="form-check text-start my-3">
            <input asp-for="RememberMe" class="form-check-input" type="checkbox" value="remember-me" id="checkDefault">
            <label class="form-check-label" for="checkDefault">Kom ihåg mig</label>
        </div>

                        <button class="btn btn-primary w-100 py-2" type="submit" style="background-color: #006039; color: white; border: none;">Logga in</button>
    </form>
</div>
