}


<link rel="stylesheet" href="~/css/login.css/">
<script></script>


<div class="loginContainer">
    <form>
        <h1 class="h3 mb-3 fw-normal">Logga in</h1> 
        <div class="form-floating"> <input type="email" class="form-control" id="floatingInput" placeholder="namn@exempel.com"> 
