@model List<Models.MaterialOrder>
@using Models

@{
    ViewData["Title"] = "Materialordrar";
    var materials = ViewBag.Materials as List<Material>;

    var completedOrders = Model?
        .Where(o => o.Status == "Klar")
        .OrderByDescending(o => o.CreatedAt)
        .ToList() ?? new List<Models.MaterialOrder>();

    var visibleCompletedOrders = completedOrders.Take(3).ToList();
    var hiddenCompletedOrders = completedOrders.Skip(3).ToList();
}

<div style="padding: 12px 16px;">

    <h1>Materialordrar</h1>

    <div style="display:flex; gap:30px; align-items:flex-start;">

        <div style="flex:2;">
            <h2>Skapa ny materialorder</h2>

            <form asp-controller="MaterialOrder" asp-action="Create" method="post">

                <div class="mb-3">
                    <label><strong>Leverantör</strong></label>
                    <input type="text" name="Supplier" class="form-control" placeholder="Ange leverantör" required />
                </div>

                <div id="materialRows">
                    <div class="material-row" style="margin-bottom:10px;">
                        <select name="Items[0].MaterialId">
                            <option value="">Välj material</option>
                            @if (materials != null)
                            {
                                @foreach (var material in materials)
                                {
                                    <option value="@material.Id">@material.Name - @material.PricePerUnit kr/@material.Unit</option>
                                }
                            }
                        </select>

                        <input type="number" name="Items[0].Quantity" step="0.1" min="0.1" placeholder="Antal" />

                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeMaterialOrderRow(this)">
                            X
                        </button>
                    </div>
                </div>

                <button type="button" class="btn btn-outline-primary me-2" onclick="addMaterialRow()">
                    Lägg till material
                </button>

                <button type="submit" class="btn btn-primary">
                    Beställ
                </button>
            </form>

            <hr />

            <h2>Påbörjade materialordrar</h2>

            @if (Model == null || !Model.Any(o => o.Status != "Klar" && o.Status != "Avbruten"))
            {
                <p>Det finns inga påbörjade materialordrar.</p>
            }
            else
            {
                @foreach (var order in Model.Where(o => o.Status != "Klar" && o.Status != "Avbruten").OrderByDescending(o => o.CreatedAt))
                {
                    <div style="border:1px solid #ccc; padding:15px; margin-bottom:15px; border-radius:8px; background-color:white;">
                        <p><strong>Datum:</strong> @order.CreatedAt.ToString("yyyy-MM-dd")</p>
                        <p><strong>Ordernummer:</strong> @order.Id</p>
                        <p><strong>Leverantör:</strong> @order.Supplier</p>
                        <p><strong>Status:</strong> @order.Status</p>
                        <p><strong>Slutsumma:</strong> @order.TotalPrice kr</p>

                        <ul>
                            @foreach (var item in order.Items)
                            {
                                <li>@item.MaterialName - @item.Quantity - @item.PricePerUnit kr/st</li>
                            }
                        </ul>

                        <form asp-controller="MaterialOrder" asp-action="MarkAsDone" method="post" style="display:inline-block;">
                            <input type="hidden" name="id" value="@order.Id" />
                            <button type="submit" class="btn btn-success">
                                Markera som klar
                            </button>
                        </form>

                        <form asp-controller="MaterialOrder" asp-action="Cancel" method="post" style="display:inline-block; margin-left:8px;">
                            <input type="hidden" name="id" value="@order.Id" />
                            <button type="submit"
                                    class="btn btn-outline-danger"
                                    onclick="return confirm('Är du säker på att du vill avbryta denna materialorder?')">
                                Avbryt order
                            </button>
                        </form>
                    </div>
                }
            }
        </div>

        <div style="flex:1;">
            <h2>Klara materialordrar</h2>

            @if (!completedOrders.Any())
            {
                <p>Det finns inga klara materialordrar.</p>
            }
            else
            {
                @foreach (var order in visibleCompletedOrders)
                {
                    <div style="border:1px solid #7fbf7f; padding:8px; margin-bottom:10px; border-radius:6px; background-color:rgba(0, 128, 0, 0.12); font-size:0.9rem;">
                        <p style="margin:0 0 4px 0;"><strong>Datum:</strong> @order.CreatedAt.ToString("yyyy-MM-dd")</p>
                        <p style="margin:0 0 4px 0;"><strong>Ordernummer:</strong> @order.Id</p>
                        <p style="margin:0 0 4px 0;"><strong>Leverantör:</strong> @order.Supplier</p>
                        <p style="margin:0 0 4px 0;"><strong>Status:</strong> @order.Status</p>
                        <p style="margin:0 0 6px 0;"><strong>Slutsumma:</strong> @order.TotalPrice kr</p>

                        <ul style="margin:0; padding-left:18px;">
                            @foreach (var item in order.Items)
                            {
                                <li>@item.MaterialName - @item.Quantity</li>
                            }
                        </ul>

                        <a asp-controller="MaterialOrder"
                               asp-action="Print"
                               asp-route-id="@order.Id"
                               target="_blank"
                               class="btn btn-primary mt-2">
                            Skriv ut
                        </a>
                    </div>
                }

                @if (hiddenCompletedOrders.Any())
                {
                    <button type="button" class="btn btn-secondary mt-2" onclick="toggleCompletedOrders()" id="toggleButton">
                        Visa mer
                    </button>

                    <div id="moreCompletedOrders" style="display:none; margin-top:10px;">
                        @foreach (var order in hiddenCompletedOrders)
                        {
                            <div style="border:1px solid #7fbf7f; padding:8px; margin-bottom:10px; border-radius:6px; background-color:rgba(0, 128, 0, 0.12); font-size:0.9rem;">
                                <p style="margin:0 0 4px 0;"><strong>Datum:</strong> @order.CreatedAt.ToString("yyyy-MM-dd")</p>
                                <p style="margin:0 0 4px 0;"><strong>Ordernummer:</strong> @order.Id</p>
                                <p style="margin:0 0 4px 0;"><strong>Leverantör:</strong> @order.Supplier</p>
                                <p style="margin:0 0 4px 0;"><strong>Status:</strong> @order.Status</p>
                                <p style="margin:0 0 6px 0;"><strong>Slutsumma:</strong> @order.TotalPrice kr</p>

                                <ul style="margin:0; padding-left:18px;">
                                    @foreach (var item in order.Items)
                                    {
                                        <li>@item.MaterialName - @item.Quantity</li>
                                    }
                                </ul>

                                <a asp-controller="MaterialOrder"
                                       asp-action="Print"
                                       asp-route-id="@order.Id"
                                       target="_blank"
                                       class="btn btn-primary mt-2">
                                    Skriv ut
                                </a>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

<script>
    let rowIndex = 1;

    function addMaterialRow() {
        const container = document.getElementById("materialRows");

        const newRow = document.createElement("div");
        newRow.className = "material-row";
        newRow.style.marginBottom = "10px";

        newRow.innerHTML = `
            <select name="Items[${rowIndex}].MaterialId">
                <option value="">Välj material</option>
                @if (materials != null)
                {
                        foreach (var material in materials)
                        {
                                <text><option value="@material.Id">@material.Name - @material.PricePerUnit kr/@material.Unit</option></text>
                        }
                }
            </select>

            <input type="number" name="Items[${rowIndex}].Quantity" step="0.1" min="0.1" placeholder="Antal" />

            <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeMaterialOrderRow(this)">
                X
            </button>
        `;

        container.appendChild(newRow);
        rowIndex++;
    }

    function removeMaterialOrderRow(button) {
        const row = button.closest(".material-row");

        if (row) {
            row.remove();
        }
    }

    function toggleCompletedOrders() {
        const moreOrders = document.getElementById("moreCompletedOrders");
        const button = document.getElementById("toggleButton");

        if (moreOrders.style.display === "none") {
            moreOrders.style.display = "block";
            button.textContent = "Visa mindre";
        } else {
            moreOrders.style.display = "none";
            button.textContent = "Visa mer";
        }
    }
</script>